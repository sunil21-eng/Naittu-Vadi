<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>Addresses - AllScouts</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --primary-color: #3a86ff;
            --danger-color: #e63946;
            --success-color: #2a9d8f;
            --text-color: #333;
            --light-gray: #f8f9fa;
            --border-color: #dee2e6;
            --sidebar-bg: #2c3e50;
            --sidebar-active: #3498db;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-color);
            background-color: #fff;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            width: 100%;
        }
        
        .addresses-header {
            background-color: var(--light-gray);
            padding: clamp(20px, 5vw, 40px) 0 clamp(15px, 4vw, 25px);
            text-align: center;
            margin-bottom: 25px;
        }
        
        .addresses-title {
            font-size: clamp(1.4rem, 5vw, 1.8rem);
            font-weight: 700;
            margin-bottom: 10px;
            padding: 0 15px;
        }
        
        .breadcrumb {
            justify-content: center;
            background: transparent;
            font-size: clamp(0.75rem, 3vw, 0.85rem);
            margin-bottom: 0;
            flex-wrap: wrap;
            padding: 0 10px;
        }
        
        .breadcrumb-item a {
            color: var(--primary-color);
            text-decoration: none;
        }
        
        /* MAIN LAYOUT - FLEX RESPONSIVE */
        .addresses-container {
            display: flex;
            max-width: 1400px;
            width: 98%;
            margin: 0 auto 25px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            overflow: hidden;
            min-height: 500px;
            transition: all 0.2s ease;
            position: relative;
        }

        /* Sidebar Styles - Desktop first */
        .addresses-sidebar {
            width: 260px;
            background-color: var(--sidebar-bg);
            color: white;
            padding: 20px 0;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .addresses-sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .addresses-sidebar-menu li {
            margin: 0;
        }

        .addresses-sidebar-menu a {
            display: flex;
            align-items: center;
            padding: clamp(10px, 2vw, 12px) clamp(15px, 3vw, 20px);
            color: #ecf0f1;
            text-decoration: none;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
            font-size: clamp(0.85rem, 3vw, 0.95rem);
            font-weight: 500;
            white-space: nowrap;
        }

        .addresses-sidebar-menu a:hover {
            background-color: #34495e;
            color: white;
        }

        .addresses-sidebar-menu a.addresses-active {
            background-color: var(--sidebar-active);
            border-left-color: #2980b9;
            color: white;
        }

        .addresses-sidebar-menu i {
            margin-right: clamp(8px, 2vw, 12px);
            width: 20px;
            text-align: center;
            font-size: clamp(0.9rem, 3vw, 1rem);
        }

        .addresses-logout {
            padding: clamp(15px, 4vw, 20px) clamp(15px, 4vw, 20px) 10px;
            margin-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        .addresses-logout-btn {
            width: 100%;
            padding: clamp(10px, 2vw, 12px);
            background-color: var(--danger-color);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: background-color 0.3s, transform 0.1s;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: clamp(0.85rem, 3vw, 0.9rem);
            min-height: 44px;
        }

        .addresses-logout-btn:hover {
            background-color: #c0392b;
            transform: scale(0.98);
        }

        .addresses-logout-btn i {
            margin-right: 8px;
        }

        /* Main Content Styles */
        .addresses-main-content {
            flex: 1;
            padding: clamp(14px, 4vw, 28px) clamp(12px, 4vw, 30px);
            background: #ffffff;
            overflow-x: hidden;
            width: 100%;
        }

        .addresses-page-title {
            font-size: clamp(1.3rem, 5vw, 1.6rem);
            margin-bottom: 5px;
            color: #2c3e50;
            font-weight: 600;
            word-break: break-word;
        }

        .addresses-page-subtitle {
            color: #7f8c8d;
            margin-bottom: clamp(16px, 4vw, 24px);
            font-size: clamp(0.85rem, 3vw, 0.95rem);
            border-left: 3px solid var(--primary-color);
            padding-left: 12px;
        }

        /* Address Section */
        .addresses-section {
            margin-bottom: 25px;
            padding: clamp(14px, 4vw, 20px) clamp(14px, 4vw, 24px);
            background: white;
            border-radius: 12px;
            box-shadow: 0 1px 5px rgba(0,0,0,0.05);
            border: 1px solid var(--border-color);
        }

        .addresses-section-title {
            font-size: clamp(1.1rem, 4vw, 1.25rem);
            margin-bottom: 20px;
            color: #2c3e50;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            font-weight: 600;
        }

        .addresses-add-btn {
            background-color: var(--primary-color);
            color: white;
            border: none;
            border-radius: 40px;
            padding: clamp(8px, 2vw, 10px) clamp(16px, 3vw, 20px);
            display: inline-flex;
            align-items: center;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            font-size: clamp(0.8rem, 3vw, 0.85rem);
            font-weight: 500;
            letter-spacing: 0.3px;
            min-height: 44px;
            justify-content: center;
        }

        .addresses-add-btn i {
            margin-right: 8px;
            font-size: clamp(0.85rem, 3vw, 0.9rem);
        }

        .addresses-add-btn:hover {
            background-color: #2a75e6;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(58,134,255,0.2);
        }

        /* Address Cards Grid - fully responsive */
        .addresses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
            gap: clamp(12px, 3vw, 20px);
        }

        .addresses-card {
            background-color: var(--light-gray);
            border-radius: 12px;
            padding: clamp(14px, 3vw, 18px);
            position: relative;
            border: 1px solid var(--border-color);
            transition: all 0.25s ease;
            box-shadow: 0 1px 2px rgba(0,0,0,0.03);
            word-break: break-word;
        }

        .addresses-card:hover {
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
            transform: translateY(-3px);
            border-color: #cbd5e0;
        }

        /* Default address card styling */
        .addresses-card.default {
            border: 2px solid var(--primary-color) !important;
            background-color: rgba(58, 134, 255, 0.04) !important;
            box-shadow: 0 4px 10px rgba(58,134,255,0.1);
        }

        /* Default badge styling */
        .addresses-default-badge {
            position: absolute;
            top: -10px;
            right: -8px;
            background-color: var(--primary-color) !important;
            color: white;
            font-size: clamp(0.6rem, 2.5vw, 0.7rem);
            padding: 4px 12px;
            border-radius: 30px;
            font-weight: 600;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            letter-spacing: 0.3px;
            white-space: nowrap;
        }

        .addresses-type {
            font-weight: 700;
            margin-bottom: 10px;
            display: inline-block;
            color: #1e293b;
            font-size: clamp(0.8rem, 3vw, 0.9rem);
            background: #e9ecef;
            padding: 4px 14px;
            border-radius: 20px;
        }

        .addresses-details {
            margin-bottom: 16px;
            line-height: 1.6;
            color: #334155;
            font-size: clamp(0.8rem, 3vw, 0.85rem);
        }

        .addresses-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .addresses-btn {
            padding: clamp(6px, 1.5vw, 7px) clamp(8px, 2vw, 12px);
            border-radius: 30px;
            cursor: pointer;
            font-size: clamp(0.7rem, 2.5vw, 0.75rem);
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            flex: 1 1 auto;
            text-decoration: none;
            border: none;
            gap: 5px;
            min-height: 36px;
        }

        .addresses-btn i {
            font-size: clamp(0.75rem, 2.5vw, 0.8rem);
        }

        .addresses-edit-btn {
            background-color: var(--primary-color);
            color: white;
        }

        .addresses-edit-btn:hover {
            background-color: #2a75e6;
            transform: translateY(-1px);
        }

        .addresses-default-btn {
            background-color: #f1f5f9;
            color: #1e293b;
            border: 1px solid #cbd5e1;
        }

        .addresses-default-btn:hover {
            background-color: #e2e8f0;
            transform: translateY(-1px);
        }

        .addresses-delete-btn {
            background-color: #fee2e2;
            color: var(--danger-color);
            border: 1px solid #fecaca;
        }

        .addresses-delete-btn:hover {
            background-color: #fecaca;
            transform: translateY(-1px);
        }

        .addresses-empty {
            text-align: center;
            padding: clamp(30px, 8vw, 40px) 20px;
            background-color: var(--light-gray);
            border-radius: 16px;
            margin-top: 20px;
        }

        .addresses-empty i {
            font-size: clamp(2.5rem, 8vw, 3rem);
            color: #94a3b8;
            margin-bottom: 15px;
        }

        .addresses-empty p {
            font-size: clamp(0.9rem, 3vw, 1rem);
            color: #475569;
            margin-bottom: 20px;
        }

        /* Modal Styles */
        .addresses-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.6);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1100;
            backdrop-filter: blur(3px);
            padding: 16px;
        }

        .addresses-modal {
            background-color: white;
            border-radius: 20px;
            width: 90%;
            max-width: 400px;
            padding: clamp(18px, 5vw, 24px);
            box-shadow: 0 20px 35px rgba(0, 0, 0, 0.2);
            animation: modalFadeIn 0.2s ease;
            max-height: 90vh;
            overflow-y: auto;
        }

        @keyframes modalFadeIn {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .addresses-modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border-color);
        }

        .addresses-modal-header h3 {
            margin: 0;
            font-size: clamp(1.2rem, 4vw, 1.3rem);
            font-weight: 700;
            color: #0f172a;
        }

        .addresses-modal-close {
            cursor: pointer;
            font-size: clamp(1.1rem, 3.5vw, 1.2rem);
            color: #64748b;
            transition: color 0.2s;
            padding: 8px;
            min-width: 44px;
            min-height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .addresses-modal-close:hover {
            color: #0f172a;
        }

        .addresses-modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 24px;
            flex-wrap: wrap;
        }

        .addresses-modal-btn {
            padding: clamp(10px, 2.5vw, 12px) clamp(16px, 4vw, 20px);
            border-radius: 40px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
            border: none;
            font-size: clamp(0.85rem, 3vw, 0.9rem);
            min-height: 44px;
            flex: 1;
            min-width: 100px;
        }

        .addresses-modal-primary {
            background-color: var(--primary-color);
            color: white;
        }

        .addresses-modal-secondary {
            background-color: #f1f5f9;
            color: #334155;
            border: 1px solid #cbd5e1;
        }

        .addresses-modal-danger {
            background-color: var(--danger-color);
            color: white;
        }

        /* Alerts */
        .addresses-alert {
            padding: clamp(10px, 3vw, 12px) clamp(12px, 3vw, 16px);
            border-radius: 12px;
            margin-bottom: 20px;
            font-weight: 500;
            font-size: clamp(0.8rem, 3vw, 0.85rem);
            display: flex;
            align-items: center;
            gap: 8px;
            word-break: break-word;
        }

        .addresses-alert-success {
            background-color: #e0f2fe;
            color: #0369a1;
            border-left: 4px solid #0284c7;
        }

        .addresses-alert-error {
            background-color: #fee2e2;
            color: #b91c1c;
            border-left: 4px solid #dc2626;
        }

        footer {
            margin-top: 20px !important;
        }

        footer p {
            font-size: clamp(0.75rem, 3vw, 0.85rem) !important;
            padding: 0 10px;
        }

        /* Touch-friendly improvements */
        @media (hover: none) and (pointer: coarse) {
            .addresses-sidebar-menu a,
            .addresses-logout-btn,
            .addresses-btn,
            .addresses-add-btn,
            .addresses-modal-btn,
            .addresses-modal-close {
                min-height: 44px;
            }
        }

        /* ========== RESPONSIVE BREAKPOINTS ========== */
        /* Tablet and Mobile styles */
        @media (max-width: 992px) {
            .addresses-container {
                flex-direction: column;
                width: 95%;
            }
            
            .addresses-sidebar {
                width: 100%;
                padding: 10px 0;
            }
            
            .addresses-sidebar-menu {
                display: flex;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: thin;
                padding-bottom: 5px;
            }
            
            .addresses-sidebar-menu::-webkit-scrollbar {
                height: 4px;
            }
            
            .addresses-sidebar-menu::-webkit-scrollbar-thumb {
                background-color: rgba(255,255,255,0.3);
                border-radius: 4px;
            }
            
            .addresses-sidebar-menu li {
                flex-shrink: 0;
            }
            
            .addresses-sidebar-menu a {
                border-left: none;
                border-bottom: 3px solid transparent;
                white-space: nowrap;
                padding: 12px 15px;
            }
            
            .addresses-sidebar-menu a.addresses-active {
                border-left: none;
                border-bottom-color: #2980b9;
            }
            
            .addresses-logout {
                padding: 10px 15px;
                margin-top: 10px;
            }
            
            .addresses-main-content {
                padding: 20px 16px;
                width: 100%;
            }
        }

        @media (max-width: 768px) {
            .addresses-container {
                width: 100%;
                margin: 0 0 25px;
                border-radius: 0;
            }
            
            .addresses-header {
                margin-bottom: 15px;
            }
            
            .addresses-main-content {
                padding: 20px 15px;
            }
            
            .addresses-section {
                padding: 16px 15px;
            }
            
            .addresses-section-title {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
            
            .addresses-add-btn {
                width: 100%;
                justify-content: center;
            }
            
            .addresses-actions {
                flex-direction: row;
                flex-wrap: wrap;
            }
            
            .addresses-btn {
                flex: 1;
                min-width: 70px;
            }
            
            .addresses-card {
                padding: 16px 14px;
            }
            
            .addresses-default-badge {
                font-size: 0.65rem;
                padding: 4px 10px;
                top: -8px;
                right: -6px;
            }
        }

        @media (max-width: 576px) {
            .addresses-main-content {
                padding: 15px 12px;
            }
            
            .addresses-grid {
                grid-template-columns: 1fr;
                gap: 14px;
            }
            
            .addresses-section {
                padding: 14px 12px;
            }
            
            .addresses-modal {
                width: 95%;
                padding: 18px 16px;
            }
            
            .addresses-sidebar-menu a {
                padding: 10px 12px;
                font-size: 0.85rem;
            }
            
            .addresses-sidebar-menu i {
                margin-right: 6px;
                font-size: 0.85rem;
            }
            
            .addresses-actions {
                gap: 6px;
            }
            
            .addresses-btn {
                padding: 8px 6px;
                font-size: 0.7rem;
            }
            
            .addresses-logout-btn {
                padding: 12px;
                font-size: 0.9rem;
            }
        }

        @media (max-width: 400px) {
            .addresses-actions {
                flex-direction: column;
                width: 100%;
            }
            
            .addresses-btn {
                width: 100%;
            }
            
            .addresses-modal-actions {
                flex-direction: column;
            }
            
            .addresses-modal-btn {
                width: 100%;
            }
            
            .addresses-default-badge {
                position: static;
                display: inline-block;
                margin-bottom: 10px;
                transform: none;
            }
            
            .addresses-card.default {
                padding-top: 16px;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/user/header') %>

    <!-- Addresses Header -->
    <section class="addresses-header">
        <div class="container">
            <h1 class="addresses-title">My Addresses</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="profile">Profile</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Addresses</li>
                </ol>
            </nav>
        </div>
    </section>

    <!-- Addresses Content -->
    <div class="addresses-container">
        <!-- Sidebar - Now at top on mobile like profile page -->
        <aside class="addresses-sidebar">
            <ul class="addresses-sidebar-menu">
                <li><a href="/profile"><i class="fas fa-user"></i> Profile</a></li>
                <li><a href="/my-orders"><i class="fas fa-shopping-bag"></i> Orders</a></li>
                <li><a href="/addresses" class="addresses-active"><i class="fas fa-map-marker-alt"></i> Addresses</a></li>
                <li><a href="/wallet"><i class="fas fa-wallet"></i> Wallet</a></li>
                <li><a href="/changePassword"><i class="fas fa-key"></i> Change Password</a></li>
            </ul>
            <div class="addresses-logout">
                <button class="addresses-logout-btn" id="logoutBtn">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="addresses-main-content">
            <h1 class="addresses-page-title">My Addresses</h1>
            <p class="addresses-page-subtitle">Manage your saved addresses</p>

            <!-- Address Section -->
            <div class="addresses-section">
                <div class="addresses-section-title">
                    <span>Saved Addresses</span>
                    <a href="/addAddress" class="addresses-add-btn">
                        <i class="fas fa-plus"></i> Add New Address
                    </a>
                </div>

                <!-- Display success/error messages -->
                <% if (messages && messages.success) { %>
                  <div class="addresses-alert addresses-alert-success" role="alert">
                    <i class="fas fa-check-circle"></i> <%= messages.success %>
                  </div>
                <% } %>
                
                <% if (messages && messages.error) { %>
                  <div class="addresses-alert addresses-alert-error" role="alert">
                    <i class="fas fa-exclamation-circle"></i> <%= messages.error %>
                  </div>
                <% } %>

                <!-- Addresses Grid -->
                <% if (addresses && addresses.length > 0) { %>
                  <div class="addresses-grid">
                    <% addresses.forEach(address => { %>
                      <div class="addresses-card <%= address.isDefault ? 'default' : '' %>">
                        <% if (address.isDefault) { %>
                          <div class="addresses-default-badge">Default</div>
                        <% } %>
                        <span class="addresses-type"><%= address.saveAs %></span>
                        <div class="addresses-details">
                          <strong><%= address.name %></strong><br>
                          <%= address.houseName %>, <%= address.street %><br>
                          <%= address.city %>, <%= address.state %> - <%= address.pincode %><br>
                          <%= address.country %><br>
                          <strong>Phone:</strong> <%= address.number %><br>
                          <strong>Email:</strong> <%= address.email %>
                        </div>
                        <div class="addresses-actions">
                          <a href="/editAddress/<%= address._id %>" class="addresses-btn addresses-edit-btn">
                            <i class="fas fa-edit"></i> Edit
                          </a>
                          <% if (!address.isDefault) { %>
                            <button class="addresses-btn addresses-default-btn" onclick="setDefaultAddress('<%= address._id %>')">
                              <i class="fas fa-check-circle"></i> Set Default
                            </button>
                            <button class="addresses-btn addresses-delete-btn" onclick="confirmDelete('<%= address._id %>')">
                              <i class="fas fa-trash"></i> Delete
                            </button>
                          <% } %>
                        </div>
                      </div>
                    <% }); %>
                  </div>
                <% } else { %>
                  <!-- No addresses message -->
                  <div class="addresses-empty">
                    <i class="fas fa-map-marker-alt"></i>
                    <p>You don't have any saved addresses yet.</p>
                    <a href="/addAddress" class="addresses-add-btn">
                      <i class="fas fa-plus"></i> Add Your First Address
                    </a>
                  </div>
                <% } %>
            </div>
        </main>
    </div>

    <!-- Footer Section -->
    <footer class="bg-light py-3 mt-3">
        <div class="container text-center">
            <p class="mb-0">&copy; 2023 Your Store. All rights reserved.</p>
        </div>
    </footer>

    <!-- Confirm Delete Modal -->
    <div class="addresses-overlay" id="deleteConfirmModal">
        <div class="addresses-modal">
            <div class="addresses-modal-header">
                <h3>Delete Address</h3>
                <div class="addresses-modal-close" onclick="closeModal('deleteConfirmModal')" role="button" aria-label="Close">
                    <i class="fas fa-times"></i>
                </div>
            </div>
            <p style="margin-bottom: 15px; color: #334155; font-size: clamp(0.85rem, 3vw, 0.9rem);">Are you sure you want to delete this address? This action cannot be undone.</p>
            <div class="addresses-modal-actions">
                <button type="button" class="addresses-modal-btn addresses-modal-secondary" onclick="closeModal('deleteConfirmModal')">Cancel</button>
                <button type="button" id="confirmDeleteBtn" class="addresses-modal-btn addresses-modal-danger">Delete Address</button>
            </div>
        </div>
    </div>

    <script>
        // Global variable to store the address ID for deletion
        let addressToDelete = null;

        // Logout functionality
        document.getElementById('logoutBtn').addEventListener('click', async () => {
            try {
                const res = await fetch('/logout', { method: 'POST' });
                if (res.ok) {
                    window.location.href = '/';
                } else {
                    console.error('Logout failed');
                    alert('Logout failed. Please try again.');
                }
            } catch (error) {
                console.error('Error during logout:', error);
                alert('An error occurred during logout. Please try again.');
            }
        });

        // Close modal
        function closeModal(modalId) {
            document.getElementById(modalId).style.display = 'none';
            addressToDelete = null;
            document.body.style.overflow = '';
        }

        // Confirm delete address
        function confirmDelete(addressId) {
            addressToDelete = addressId;
            document.getElementById('deleteConfirmModal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
            
            document.getElementById('confirmDeleteBtn').onclick = function() {
                deleteAddress(addressToDelete);
            };
        }

        // Delete address function
        async function deleteAddress(addressId) {
            try {
                const response = await fetch('/deleteAddress', {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ addressId: addressId })
                });

                const data = await response.json();

                if (data.success) {
                    window.location.href = '/addresses?message=' + encodeURIComponent(data.message);
                } else {
                    alert('Error: ' + (data.message || 'Failed to delete address'));
                    closeModal('deleteConfirmModal');
                }
            } catch (error) {
                console.error('Error deleting address:', error);
                alert('Failed to delete address. Please try again.');
                closeModal('deleteConfirmModal');
            }
        }

        // Set default address
        async function setDefaultAddress(addressId) {
            try {
                const response = await fetch('/setDefaultAddress', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ addressId: addressId })
                });

                const data = await response.json();

                if (data.success) {
                    window.location.href = '/addresses?message=' + encodeURIComponent(data.message);
                } else {
                    alert('Error: ' + (data.message || 'Failed to set default address'));
                }
            } catch (error) {
                console.error('Error setting default address:', error);
                alert('Failed to set default address. Please try again.');
            }
        }

        // Close modals when clicking outside
        window.addEventListener('click', function(e) {
            const deleteConfirmModal = document.getElementById('deleteConfirmModal');
            if (e.target === deleteConfirmModal) {
                closeModal('deleteConfirmModal');
            }
        });

        // Auto-hide success messages after 5 seconds
        document.addEventListener('DOMContentLoaded', function() {
            const successAlert = document.querySelector('.addresses-alert-success');
            if (successAlert) {
                setTimeout(() => {
                    successAlert.style.transition = 'opacity 0.3s';
                    successAlert.style.opacity = '0';
                    setTimeout(() => {
                        successAlert.style.display = 'none';
                    }, 300);
                }, 5000);
            }
            
            // Sidebar navigation highlighting
            const currentPage = window.location.pathname;
            const sidebarLinks = document.querySelectorAll('.addresses-sidebar-menu a');
            sidebarLinks.forEach(link => {
                if (link.getAttribute('href') === currentPage) {
                    link.classList.add('addresses-active');
                } else {
                    link.classList.remove('addresses-active');
                }
            });
        });

        // Handle escape key to close modal
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                const deleteConfirmModal = document.getElementById('deleteConfirmModal');
                if (deleteConfirmModal && deleteConfirmModal.style.display === 'flex') {
                    closeModal('deleteConfirmModal');
                }
            }
        });
    </script>
</body>
<%- include('../partials/user/footer') %>
</html>