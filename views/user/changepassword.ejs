<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password - AllScouts</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --primary-color: #3a86ff;
            --danger-color: #e63946;
            --success-color: #2a9d8f;
            --text-color: #333;
            --light-gray: #f8f9fa;
            --border-color: #dee2e6;
            --sidebar-bg: #2c3e50;
            --sidebar-active: #3498db;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-color);
            background-color: #fff;
            margin: 0;
            padding: 0;
        }

        .change-password-header {
            background-color: var(--light-gray);
            padding: 40px 0 25px;
            text-align: center;
            margin-bottom: 25px;
        }

        .change-password-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .breadcrumb {
            justify-content: center;
            background: transparent;
            font-size: 0.85rem;
            margin-bottom: 0;
        }

        .breadcrumb-item a {
            color: var(--primary-color);
            text-decoration: none;
        }

        .change-password-container {
            display: flex;
            max-width: 98%;
            margin: 0 auto 25px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            min-height: 500px;
        }

        /* Sidebar Styles */
        .change-password-sidebar {
            width: 220px;
            background-color: var(--sidebar-bg);
            color: white;
            padding: 20px 0;
        }

        .change-password-sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .change-password-sidebar-menu li {
            margin: 0;
        }

        .change-password-sidebar-menu a {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: #ecf0f1;
            text-decoration: none;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
            font-size: 0.9rem;
        }

        .change-password-sidebar-menu a:hover {
            background-color: #34495e;
            color: white;
        }

        .change-password-sidebar-menu a.change-password-active {
            background-color: var(--sidebar-active);
            border-left-color: #2980b9;
            color: white;
        }

        .change-password-sidebar-menu i {
            margin-right: 8px;
            width: 16px;
            text-align: center;
            font-size: 0.9rem;
        }

        .change-password-logout {
            padding: 15px 20px;
            margin-top: 15px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .change-password-logout-btn {
            width: 100%;
            padding: 10px;
            background-color: var(--danger-color);
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 500;
            transition: background-color 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
        }

        .change-password-logout-btn:hover {
            background-color: #c0392b;
        }

        .change-password-logout-btn i {
            margin-right: 6px;
        }

        /* Main Content Styles */
        .change-password-main-content {
            flex: 1;
            padding: 25px;
        }

        .change-password-page-title {
            font-size: 1.5rem;
            margin-bottom: 5px;
            color: #2c3e50;
            font-weight: 600;
        }

        .change-password-page-subtitle {
            color: #7f8c8d;
            margin-bottom: 20px;
            font-size: 0.9rem;
        }

        /* Password Section */
        .change-password-section {
            margin-bottom: 25px;
            padding: 20px;
            background: white;
            border-radius: 6px;
            box-shadow: 0 1px 5px rgba(0, 0, 0, 0.05);
            border: 1px solid var(--border-color);
        }

        .change-password-section-title {
            font-size: 1.2rem;
            margin-bottom: 15px;
            color: #2c3e50;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 10px;
            font-weight: 600;

        }

        /* Password Form */
        .change-password-form {
            max-width: 450px;
            margin: 0 auto;
        }

        .change-password-form-group {
            margin-bottom: 15px;
        }

        .change-password-form-label {
            display: block;
            margin-bottom: 6px;
            font-weight: 600;
            color: var(--text-color);
            font-size: 0.9rem;
        }

        .change-password-input-container {
            position: relative;
        }

        .change-password-form-control {
            width: 100%;
            padding: 10px 35px 10px 12px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            font-size: 0.9rem;
            transition: all 0.3s;
            box-sizing: border-box;
        }

        .change-password-form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 2px rgba(58, 134, 255, 0.2);
            outline: none;
        }

        .change-password-toggle {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #666;
            font-size: 1rem;
        }

        .change-password-strength {
            height: 4px;
            margin-top: 6px;
            border-radius: 2px;
            background-color: #eee;
            overflow: hidden;
        }

        .change-password-strength-meter {
            height: 100%;
            width: 0;
            border-radius: 2px;
            transition: all 0.3s;
        }

        .change-password-feedback {
            font-size: 0.8rem;
            margin-top: 4px;
        }

        .change-password-requirements {
            margin-top: 8px;
            font-size: 0.8rem;
            color: #666;
        }

        .change-password-requirement {
            display: flex;
            align-items: center;
            gap: 5px;
            margin-bottom: 2px;
        }

        .change-password-requirement i {
            font-size: 0.8rem;
        }

        .change-password-valid {
            color: var(--success-color);
        }

        .change-password-invalid {
            color: #999;
        }

        .change-password-form-actions {
            display: flex;
            justify-content: center;
            margin-top: 25px;
        }

        .change-password-btn {
            padding: 10px 25px;
            border-radius: 4px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            border: none;
            font-size: 0.9rem;
        }

        .change-password-btn-primary {
            background-color: var(--primary-color);
            color: white;
        }

        .change-password-btn-primary:hover {
            background-color: #2a75e6;
            transform: translateY(-1px);
        }

        .change-password-btn-primary:disabled {
            background-color: #ccc;
            cursor: not-allowed;
            transform: none;
        }

        .change-password-error-message {
            color: var(--danger-color);
            font-size: 0.8rem;
            margin-top: 4px;
            display: none;
        }

        /* Success/Error Messages */
        .change-password-alert {
            padding: 10px 12px;
            border-radius: 4px;
            margin-bottom: 15px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.9rem;
            border: none;
            border-left: 3px solid transparent;
        }

        .change-password-alert-success {
            background-color: rgba(42, 157, 143, 0.1);
            color: var(--success-color);
            border-left-color: var(--success-color);
        }

        .change-password-alert-error {
            background-color: rgba(230, 57, 70, 0.1);
            color: var(--danger-color);
            border-left-color: var(--danger-color);
        }

        /* Footer */
        footer {
            margin-top: 20px !important;
        }

        /* Responsive Styles */
        @media (max-width: 992px) {
            .change-password-container {
                flex-direction: column;
                max-width: 95%;
            }

            .change-password-sidebar {
                width: 100%;
            }

            .change-password-sidebar-menu {
                display: flex;
                overflow-x: auto;
            }

            .change-password-sidebar-menu li {
                flex-shrink: 0;
            }

            .change-password-sidebar-menu a {
                border-left: none;
                border-bottom: 3px solid transparent;
                white-space: nowrap;
            }

            .change-password-sidebar-menu a.change-password-active {
                border-left: none;
                border-bottom-color: #2980b9;
            }

            .change-password-main-content {
                padding: 20px;
            }
        }

        @media (max-width: 768px) {
            .change-password-header {
                padding: 30px 0 20px;
            }

            .change-password-title {
                font-size: 1.5rem;
            }

            .change-password-form {
                max-width: 100%;
            }
        }

        @media (max-width: 576px) {
            .change-password-main-content {
                padding: 15px 12px;
            }

            .change-password-header {
                padding: 25px 0 15px;
            }

            .change-password-title {
                font-size: 1.3rem;
            }

            .change-password-section {
                padding: 15px;
            }
        }
    </style>
</head>

<body>
    <%- include('../partials/user/header') %>

        <!-- Change Password Header -->
        <section class="change-password-header">
            <div class="container">
                <h1 class="change-password-title">Change Password</h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item active">Change Password</li>
                    </ol>
                </nav>
            </div>
        </section>

        <!-- Change Password Content -->
        <div class="change-password-container">
            <!-- Sidebar -->
            <aside class="change-password-sidebar">
                <ul class="change-password-sidebar-menu">
                    <li><a href="/profile"><i class="fas fa-user"></i> Profile</a></li>
                    <li><a href="/my-orders"><i class="fas fa-shopping-bag"></i> Orders</a></li>
                    <li><a href="/addresses"><i class="fas fa-map-marker-alt"></i> Addresses</a></li>
                    <li><a href="/wallet"><i class="fas fa-wallet"></i> Wallet</a></li>
                    <li><a href="/changePassword" class="change-password-active"><i class="fas fa-key"></i> Change
                            Password</a></li>
                </ul>
                <div class="change-password-logout">
                    <button class="change-password-logout-btn" id="logoutBtn">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </button>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="change-password-main-content">
                <h1 class="change-password-page-title">Change Password</h1>
                <p class="change-password-page-subtitle">Update your account password</p>

                <!-- Password Section -->
                <div class="change-password-section">
                    <div class="change-password-section-title">
                        <span>Update Password</span>
                    </div>

                    <!-- Display success/error messages from query parameters -->
                    <% if (typeof success !=='undefined' && success) { %>
                        <div class="change-password-alert change-password-alert-success">
                            <i class="fas fa-check-circle"></i>
                            <%= success %>
                        </div>
                        <% } %>

                            <% if (typeof error !=='undefined' && error) { %>
                                <div class="change-password-alert change-password-alert-error">
                                    <i class="fas fa-exclamation-circle"></i>
                                    <%= error %>
                                </div>
                                <% } %>

                                    <!-- Dynamic Alert Container for API Responses -->
                                    <div id="apiAlertContainer"></div>

                                    <form id="changePasswordForm" class="change-password-form">
                                        <!-- Current Password -->
                                        <div class="change-password-form-group">
                                            <label for="currentPassword">Current Password</label>
                                            <div class="change-password-input-container">
                                                <input type="password" id="currentPassword" name="currentPassword"
                                                    class="change-password-form-control" required>
                                                <button type="button" class="change-password-toggle"
                                                    onclick="togglePasswordVisibility('currentPassword')">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                            </div>
                                            <div id="currentPasswordError" class="change-password-error-message"></div>
                                        </div>

                                        <!-- New Password -->
                                        <div class="change-password-form-group">
                                            <label for="newPassword">New Password</label>
                                            <div class="change-password-input-container">
                                                <input type="password" id="newPassword" name="newPassword"
                                                    class="change-password-form-control" required>
                                                <button type="button" class="change-password-toggle"
                                                    onclick="togglePasswordVisibility('newPassword')">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                            </div>
                                            <div class="change-password-strength">
                                                <div id="passwordStrengthMeter" class="change-password-strength-meter">
                                                </div>
                                            </div>
                                            <div id="passwordFeedback" class="change-password-feedback"></div>
                                            <div class="change-password-requirements">
                                                <div class="change-password-requirement" id="req-length">
                                                    <i class="fas fa-check-circle"></i> At least 8 characters
                                                </div>
                                                <div class="change-password-requirement" id="req-uppercase">
                                                    <i class="fas fa-check-circle"></i> At least one uppercase letter
                                                </div>
                                                <div class="change-password-requirement" id="req-number">
                                                    <i class="fas fa-check-circle"></i> At least one number
                                                </div>
                                            </div>
                                            <div id="newPasswordError" class="change-password-error-message"></div>
                                        </div>

                                        <!-- Confirm Password -->
                                        <div class="change-password-form-group">
                                            <label for="confirmPassword">Confirm Password</label>
                                            <div class="change-password-input-container">
                                                <input type="password" id="confirmPassword" name="confirmPassword"
                                                    class="change-password-form-control" required>
                                                <button type="button" class="change-password-toggle"
                                                    onclick="togglePasswordVisibility('confirmPassword')">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                            </div>
                                            <div id="confirmPasswordError" class="change-password-error-message"></div>
                                        </div>

                                        <!-- Submit Button -->
                                        <div class="change-password-form-actions">
                                            <button type="submit"
                                                class="change-password-btn change-password-btn-primary"
                                                id="submitButton">
                                                <i class="fas fa-lock"></i> Update Password
                                            </button>
                                        </div>
                                    </form>
                </div>
            </main>
        </div>

        <!-- Footer Section -->
        <footer class="bg-light py-3 mt-3">
            <div class="container text-center">
                <p class="mb-0" style="font-size: 0.85rem;">&copy; 2023 Your Store. All rights reserved.</p>
            </div>
        </footer>

        <script>
            // Logout functionality
            document.getElementById('logoutBtn').addEventListener('click', async () => {
                try {
                    const res = await fetch('/logout', { method: 'POST' });
                    if (res.ok) {
                        window.location.href = '/';
                    } else {
                        console.error('Logout failed');
                        alert('Logout failed. Please try again.');
                    }
                } catch (error) {
                    console.error('Error during logout:', error);
                    alert('An error occurred during logout. Please try again.');
                }
            });

            // Toggle password visibility
            function togglePasswordVisibility(inputId) {
                const input = document.getElementById(inputId);
                const icon = input.nextElementSibling.querySelector('i');

                if (input.type === 'password') {
                    input.type = 'text';
                    icon.className = 'fas fa-eye-slash';
                } else {
                    input.type = 'password';
                    icon.className = 'fas fa-eye';
                }
            }

            // Show API response message
            function showApiMessage(message, type) {
                const container = document.getElementById('apiAlertContainer');
                const alertClass = type === 'success' ? 'change-password-alert-success' : 'change-password-alert-error';
                const iconClass = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';

                container.innerHTML = `
                <div class="change-password-alert ${alertClass}">
                    <i class="fas ${iconClass}"></i>
                    ${message}
                </div>
            `;

                // Auto-hide after 5 seconds for success, 8 seconds for error
                setTimeout(() => {
                    container.innerHTML = '';
                }, type === 'success' ? 5000 : 8000);

                // Scroll to the message
                container.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }

            // Check password strength and update requirements - Updated to match backend regex
            function checkPasswordStrength(password) {
                // Requirements check - matches backend: /^(?=.*[A-Z])(?=.*\d).{8,}$/
                const requirements = {
                    length: password.length >= 8,
                    uppercase: /[A-Z]/.test(password),
                    number: /[0-9]/.test(password)
                };

                // Update requirement visuals
                for (const [req, valid] of Object.entries(requirements)) {
                    const element = document.getElementById(`req-${req}`);
                    if (element) {
                        const icon = element.querySelector('i');
                        if (valid) {
                            element.classList.add('change-password-valid');
                            element.classList.remove('change-password-invalid');
                            icon.className = 'fas fa-check-circle';
                        } else {
                            element.classList.add('change-password-invalid');
                            element.classList.remove('change-password-valid');
                            icon.className = 'fas fa-times-circle';
                        }
                    }
                }

                // Calculate strength score (0-3)
                const score = Object.values(requirements).filter(Boolean).length;

                // Update strength meter
                const strengthMeter = document.getElementById('passwordStrengthMeter');
                const feedback = document.getElementById('passwordFeedback');

                // Set width and color based on score
                strengthMeter.style.width = `${(score / 3) * 100}%`;

                let color, message;

                switch (score) {
                    case 0:
                        color = '#dc3545'; // Red
                        message = 'Very weak';
                        break;
                    case 1:
                        color = '#ffc107'; // Yellow
                        message = 'Weak';
                        break;
                    case 2:
                        color = '#fd7e14'; // Orange
                        message = 'Medium';
                        break;
                    case 3:
                        color = '#28a745'; // Green
                        message = 'Strong';
                        break;
                }

                strengthMeter.style.backgroundColor = color;
                feedback.textContent = message;
                feedback.style.color = color;

                return score === 3; // Return true only if all requirements are met
            }

            // Validate form fields
            function validateField(fieldId, errorId) {
                const field = document.getElementById(fieldId);
                const errorElement = document.getElementById(errorId);
                const value = field.value.trim();

                if (!value) {
                    errorElement.textContent = 'This field is required';
                    errorElement.style.display = 'block';
                    return false;
                }

                errorElement.style.display = 'none';
                return true;
            }

            // Validate new password specifically
            function validateNewPassword() {
                const newPassword = document.getElementById('newPassword').value;
                const errorElement = document.getElementById('newPasswordError');

                if (!newPassword) {
                    errorElement.textContent = 'New password is required';
                    errorElement.style.display = 'block';
                    return false;
                }

                // Check if password meets backend regex: /^(?=.*[A-Z])(?=.*\d).{8,}$/
                const passwordRegex = /^(?=.*[A-Z])(?=.*\d).{8,}$/;
                if (!passwordRegex.test(newPassword)) {
                    errorElement.textContent = 'Password must be at least 8 characters with 1 uppercase letter and 1 number';
                    errorElement.style.display = 'block';
                    return false;
                }

                errorElement.style.display = 'none';
                return true;
            }

            // Validate confirm password
            function validateConfirmPassword() {
                const newPassword = document.getElementById('newPassword').value;
                const confirmPassword = document.getElementById('confirmPassword').value;
                const errorElement = document.getElementById('confirmPasswordError');

                if (!confirmPassword) {
                    errorElement.textContent = 'Please confirm your password';
                    errorElement.style.display = 'block';
                    return false;
                }

                if (newPassword !== confirmPassword) {
                    errorElement.textContent = 'New password and confirm password do not match';
                    errorElement.style.display = 'block';
                    return false;
                } else {
                    errorElement.style.display = 'none';
                    return true;
                }
            }

            // Check if form is valid
            function checkFormValidity() {
                const isCurrentPasswordValid = validateField('currentPassword', 'currentPasswordError');
                const isNewPasswordValid = validateNewPassword();
                const isConfirmPasswordValid = validateConfirmPassword();

                // Also check password strength visually
                const newPassword = document.getElementById('newPassword').value;
                const isPasswordStrong = checkPasswordStrength(newPassword);

                return isCurrentPasswordValid && isNewPasswordValid && isConfirmPasswordValid && isPasswordStrong;
            }

            // Real-time validation
            function setupRealTimeValidation() {
                const fields = [
                    { field: 'currentPassword', error: 'currentPasswordError', validator: validateField },
                    { field: 'newPassword', error: 'newPasswordError', validator: validateNewPassword },
                    { field: 'confirmPassword', error: 'confirmPasswordError', validator: validateConfirmPassword }
                ];

                fields.forEach(({ field, error, validator }) => {
                    const element = document.getElementById(field);
                    if (element) {
                        element.addEventListener('blur', () => {
                            if (field === 'newPassword') {
                                validateNewPassword();
                                checkPasswordStrength(element.value);
                            } else if (field === 'confirmPassword') {
                                validateConfirmPassword();
                            } else {
                                validator(field, error);
                            }
                        });

                        element.addEventListener('input', () => {
                            const errorElement = document.getElementById(error);
                            errorElement.style.display = 'none';

                            if (field === 'newPassword') {
                                checkPasswordStrength(element.value);
                            }
                        });
                    }
                });
            }

            // Handle form submission with AJAX to properly capture backend responses
            function handleFormSubmission(e) {
                e.preventDefault();

                if (!checkFormValidity()) {
                    // Show any hidden errors
                    validateField('currentPassword', 'currentPasswordError');
                    validateNewPassword();
                    validateConfirmPassword();
                    return;
                }

                const submitButton = document.getElementById('submitButton');
                const originalText = submitButton.innerHTML;

                // Show loading state
                submitButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating...';
                submitButton.disabled = true;

                // Prepare JSON data
                const formData = {
                    currentPassword: document.getElementById('currentPassword').value,
                    newPassword: document.getElementById('newPassword').value,
                    confirmPassword: document.getElementById('confirmPassword').value
                };

                console.log('Sending JSON data:', formData);

                fetch('/changePassword', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(formData)
                })
                    .then(response => {
                        console.log('Response status:', response.status);
                        console.log('Response ok:', response.ok);

                        // Try to parse as JSON
                        return response.json().then(data => {
                            return { status: response.status, ok: response.ok, data };
                        }).catch(error => {
                            console.log('JSON parse error, trying text...');
                            return response.text().then(text => {
                                return { status: response.status, ok: response.ok, data: { message: text } };
                            });
                        });
                    })
                    .then(({ status, ok, data }) => {
                        console.log('Parsed response data:', data);

                        if (ok) {
                            showApiMessage(data.message || 'Password updated successfully!', 'success');
                            document.getElementById('changePasswordForm').reset();
                            // Reset password strength meter
                            document.getElementById('passwordStrengthMeter').style.width = '0%';
                            document.getElementById('passwordFeedback').textContent = '';
                        } else {
                            // Show the actual backend message
                            const errorMessage = data.message || data.error || `Error: ${status}`;
                            showApiMessage(errorMessage, 'error');

                            // Highlight specific field if it's a current password error
                            if (data.message && data.message.includes('Current Password')) {
                                const currentPasswordError = document.getElementById('currentPasswordError');
                                currentPasswordError.textContent = data.message;
                                currentPasswordError.style.display = 'block';
                                document.getElementById('currentPassword').focus();
                            }

                            // Highlight specific field if it's a password validation error
                            if (data.message && (data.message.includes('password must be') || data.message.includes('New password'))) {
                                const newPasswordError = document.getElementById('newPasswordError');
                                newPasswordError.textContent = data.message;
                                newPasswordError.style.display = 'block';
                                document.getElementById('newPassword').focus();
                            }
                        }
                    })
                    .catch(error => {
                        console.error('Fetch error:', error);
                        showApiMessage('Network error. Please check your connection and try again.', 'error');
                    })
                    .finally(() => {
                        // Restore button state
                        submitButton.innerHTML = originalText;
                        submitButton.disabled = false;
                    });
            }

            // Initialize event listeners
            document.addEventListener('DOMContentLoaded', function () {
                setupRealTimeValidation();

                // Replace form submission with AJAX
                document.getElementById('changePasswordForm').addEventListener('submit', handleFormSubmission);

                // Auto-hide success messages after 5 seconds
                const successAlert = document.querySelector('.change-password-alert-success');
                if (successAlert) {
                    setTimeout(() => {
                        successAlert.style.display = 'none';
                    }, 5000);
                }

                // Auto-hide error messages after 8 seconds
                const errorAlert = document.querySelector('.change-password-alert-error');
                if (errorAlert) {
                    setTimeout(() => {
                        errorAlert.style.display = 'none';
                    }, 8000);
                }

                // Clear URL parameters after page load to prevent message persistence on refresh
                if (window.location.search.includes('success=') || window.location.search.includes('error=')) {
                    const url = new URL(window.location);
                    url.searchParams.delete('success');
                    url.searchParams.delete('error');
                    window.history.replaceState({}, '', url);
                }
            });

            // Sidebar navigation highlighting
            document.addEventListener('DOMContentLoaded', function () {
                const currentPage = window.location.pathname;
                const sidebarLinks = document.querySelectorAll('.change-password-sidebar-menu a');

                sidebarLinks.forEach(link => {
                    if (link.getAttribute('href') === currentPage) {
                        link.classList.add('change-password-active');
                    } else {
                        link.classList.remove('change-password-active');
                    }
                });
            });
        </script>
</body>
<%- include('../partials/user/footer') %>

</html>