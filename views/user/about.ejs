    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        class HeaderSyncManager {
            constructor() {
                this.init();
            }

            init() {
                window.addEventListener('storage', (e) => {
                    if (e.key === 'cartSync') this.handleCartSync(e);
                    if (e.key === 'wishlistSync') this.handleWishlistSync(e);
                });

                document.addEventListener('cartUpdated', (event) => {
                    if (event.detail && event.detail.cartCount !== undefined) this.updateCartCount(event.detail.cartCount);
                    if (event.detail && event.detail.message) this.showToast(event.detail.message);
                });

                document.addEventListener('wishlistUpdated', (event) => {
                    if (event.detail && event.detail.wishlistCount !== undefined) {
                        this.updateWishlistCount(event.detail.wishlistCount);
                        this.updateWishlistStorage(event.detail.wishlistCount);
                    }
                    if (event.detail && event.detail.message) this.showToast(event.detail.message);
                });

                document.addEventListener('cartItemRemoved', (event) => {
                    if (event.detail && event.detail.cartCount !== undefined) {
                        this.updateCartCount(event.detail.cartCount);
                        this.showToast(event.detail.message || 'Item removed from cart');
                    }
                });

                this.fetchCountsFromServer();
                this.setupPeriodicSync();
            }

            handleCartSync(e) {
                if (e.newValue) {
                    try {
                        const cartData = JSON.parse(e.newValue).data;
                        if (cartData && cartData.cartCount !== undefined) this.updateCartCount(cartData.cartCount);
                    } catch (error) {}
                }
            }

            handleWishlistSync(e) {
                if (e.newValue) {
                    try {
                        const wishlistData = JSON.parse(e.newValue).data;
                        if (wishlistData && wishlistData.length !== undefined) this.updateWishlistCount(wishlistData.length);
                    } catch (error) {}
                }
            }

            updateCartCount(count) {
                const cartCountElement = document.querySelector('.cart-count');
                if (cartCountElement) {
                    const newCount = parseInt(count) || 0;
                    cartCountElement.textContent = newCount;
                    cartCountElement.classList.add('badge-pulse');
                    setTimeout(() => cartCountElement.classList.remove('badge-pulse'), 500);
                }
            }

            updateWishlistCount(count) {
                const wishlistCountElement = document.querySelector('.wishlist-count');
                if (wishlistCountElement) {
                    const newCount = parseInt(count) || 0;
                    wishlistCountElement.textContent = newCount;
                    wishlistCountElement.classList.add('badge-pulse');
                    setTimeout(() => wishlistCountElement.classList.remove('badge-pulse'), 500);
                }
            }

            updateWishlistStorage(count) {
                try {
                    localStorage.setItem('wishlistSync', JSON.stringify({ data: { length: count }, timestamp: Date.now() }));
                } catch (error) {}
            }

            clearWishlistStorage() {
                try { localStorage.removeItem('wishlistSync'); } catch (error) {}
            }

            showToast(message) {
                const toast = document.getElementById('headerToast');
                if (toast) {
                    toast.querySelector('span').textContent = message;
                    toast.style.display = 'flex';
                    setTimeout(() => toast.style.display = 'none', 3000);
                }
            }

            fetchCountsFromServer() {
                fetch('/api/header-counts')
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            this.updateCartCount(data.cartCount);
                            this.updateWishlistCount(data.wishlistCount);
                            this.updateLocalStorageFromServer(data);
                        }
                    })
                    .catch(error => console.error('Error fetching counts:', error));
            }

            updateLocalStorageFromServer(data) {
                try {
                    localStorage.setItem('cartSync', JSON.stringify({ data: { cartCount: data.cartCount }, timestamp: Date.now() }));
                    localStorage.setItem('wishlistSync', JSON.stringify({ data: { length: data.wishlistCount }, timestamp: Date.now() }));
                } catch (e) {}
            }

            setupPeriodicSync() {
                setInterval(() => this.fetchCountsFromServer(), 30000);
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            window.headerSync = new HeaderSyncManager();
        });

        window.cartWishlistSync = {
            updateCartCount: (count) => window.headerSync?.updateCartCount(count),
            updateWishlistCount: (count) => window.headerSync?.updateWishlistCount(count),
            clearWishlistStorage: () => window.headerSync?.clearWishlistStorage(),
            syncCountsWithServer: () => window.headerSync?.fetchCountsFromServer()
        };
    </script>
</body>
