<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us - Artemis Crakers</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #3a86ff;
            --secondary-color: #ff006e;
            --dark-color: #2b2d42;
            --light-color: #f8f9fa;
            --border-color: #dee2e6;
            --cracker-orange: #ff6b35;
            --cracker-gold: #ffd93d;
            --cracker-red: #e53e3e;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            background-color: #fff;
            margin: 0;
            padding: 0;
            line-height: 1.5;
        }

        .about-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 20px 15px;
        }

        /* Header Section - Simple */
        .about-header {
            text-align: center;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid var(--cracker-orange);
        }

        .about-title {
            font-size: 2rem;
            font-weight: 700;
            color: var(--dark-color);
            margin-bottom: 5px;
        }

        .about-title i {
            color: var(--cracker-orange);
            margin: 0 8px;
            font-size: 1.8rem;
        }

        .about-subtitle {
            color: #666;
            font-size: 1rem;
        }

        /* Hero Section - Simple Two Column */
        .about-hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 30px;
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .hero-content {
            padding: 30px;
        }

        .hero-content h2 {
            font-size: 1.6rem;
            font-weight: 600;
            color: var(--dark-color);
            margin-bottom: 15px;
        }

        .hero-content h2 i {
            color: var(--cracker-orange);
            margin-right: 8px;
        }

        .hero-content p {
            color: #555;
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 15px;
        }

        .hero-highlight {
            background: rgba(255, 107, 53, 0.1);
            border-left: 4px solid var(--cracker-orange);
            padding: 12px 15px;
            border-radius: 0 4px 4px 0;
            margin-top: 20px;
        }

        .hero-highlight i {
            color: var(--cracker-orange);
            margin-right: 8px;
        }

        .hero-highlight span {
            font-weight: 600;
            color: var(--cracker-red);
        }

        .hero-image {
            background: linear-gradient(135deg, #1a1b2f 0%, #2a2c4a 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .hero-image::before {
            content: '🎆 🎇 ✨ 🎆 🎇';
            position: absolute;
            font-size: 4rem;
            opacity: 0.1;
            white-space: nowrap;
            animation: moveStars 20s linear infinite;
        }

        @keyframes moveStars {
            from { transform: translateX(-100%); }
            to { transform: translateX(100%); }
        }

        .hero-image-content {
            text-align: center;
            z-index: 1;
        }

        .hero-image-content i {
            font-size: 4rem;
            color: var(--cracker-gold);
            margin-bottom: 15px;
            display: block;
        }

        .hero-image-content h3 {
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, #ff6b35, #ffd93d);
                        -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        /* Simple Stats */
        .simple-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
            text-align: center;
        }

        .stat-item {
            background: white;
            padding: 20px;
            border-radius: 6px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.03);
            border: 1px solid #eee;
        }

        .stat-item i {
            font-size: 2rem;
            color: var(--cracker-orange);
            margin-bottom: 8px;
        }

        .stat-number {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--dark-color);
            display: block;
        }

        .stat-label {
            color: #666;
            font-size: 0.9rem;
        }

        /* Values Section - Simple Cards */
        .values-section {
            margin-bottom: 30px;
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--dark-color);
            margin-bottom: 20px;
            text-align: center;
        }

        .section-title i {
            color: var(--cracker-orange);
            margin: 0 8px;
        }

        .values-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
        }

        .value-card {
            background: white;
            padding: 20px;
            border-radius: 6px;
            border: 1px solid #eee;
            text-align: center;
            transition: transform 0.3s;
        }

        .value-card:hover {
            transform: translateY(-3px);
            border-color: var(--cracker-orange);
        }

        .value-icon {
            width: 50px;
            height: 50px;
            background: rgba(255, 107, 53, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            color: var(--cracker-orange);
            font-size: 1.3rem;
        }

        .value-card h4 {
            font-size: 1rem;
            font-weight: 600;
            color: var(--dark-color);
            margin-bottom: 8px;
        }

        .value-card p {
            color: #666;
            font-size: 0.85rem;
            line-height: 1.4;
            margin: 0;
        }

        /* Safety Section - Important for crackers */
        .safety-section {
            background: linear-gradient(135deg, #fff5f0 0%, #fff0e6 100%);
            border-radius: 8px;
            padding: 25px;
            margin-bottom: 30px;
            border: 1px solid #ffd1b3;
        }

        .safety-section h3 {
            color: var(--cracker-red);
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .safety-section h3 i {
            margin-right: 10px;
        }

        .safety-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .safety-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }

        .safety-item i {
            color: var(--cracker-orange);
            font-size: 1.1rem;
            margin-top: 2px;
        }

        .safety-item p {
            margin: 0;
            color: #555;
            font-size: 0.9rem;
        }

        /* CTA Section - Simple */
        .about-cta {
            text-align: center;
            padding: 30px;
            background: var(--light-color);
            border-radius: 6px;
            border: 1px solid #eee;
        }

        .about-cta h3 {
            font-size: 1.4rem;
            font-weight: 600;
            color: var(--dark-color);
            margin-bottom: 10px;
        }

        .about-cta p {
            color: #666;
            margin-bottom: 20px;
        }

        .cta-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
        }

        .btn {
            padding: 10px 25px;
            border-radius: 4px;
            font-weight: 500;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
        }

        .btn-primary {
            background: var(--cracker-orange);
            color: white;
        }

        .btn-primary:hover {
            background: #e55a2b;
            transform: translateY(-2px);
        }

        .btn-outline {
            border: 1px solid #ddd;
            color: var(--dark-color);
        }

        .btn-outline:hover {
            background: #f5f5f5;
        }

        /* Responsive */
        @media (max-width: 992px) {
            .values-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .about-hero {
                grid-template-columns: 1fr;
            }
            
            .simple-stats {
                grid-template-columns: 1fr;
            }
            
            .safety-grid {
                grid-template-columns: 1fr;
            }
            
            .cta-buttons {
                flex-direction: column;
                align-items: center;
            }
            
            .btn {
                width: 100%;
                max-width: 250px;
            }
        }

        @media (max-width: 576px) {
            .values-grid {
                grid-template-columns: 1fr;
            }
            
            .hero-content {
                padding: 20px;
            }
            
            .hero-content h2 {
                font-size: 1.3rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/user/header') %>

    <div class="about-container">
        <!-- Simple Header -->
        <div class="about-header">
            <h1 class="about-title">
                <i class="fas fa-star"></i>
                About Artemis Crakers
                <i class="fas fa-star"></i>
            </h1>
            <p class="about-subtitle">Lighting up celebrations since 2015</p>
        </div>

        <!-- Hero Section -->
        <div class="about-hero">
            <div class="hero-content">
                <h2>
                    <i class="fas fa-fire"></i>
                    Our Story
                </h2>
                <p>
                    Founded in 2015, Artemis Crakers started with a simple mission: to bring safe, 
                    high-quality fireworks to every celebration. What began as a small family workshop 
                    in Chennai has grown into one of South India's most trusted cracker brands.
                </p>
                <p>
                    We combine traditional craftsmanship with modern safety standards to create 
                    fireworks that light up your special moments. From Diwali to weddings, our 
                    products have been part of countless happy celebrations.
                </p>
                <div class="hero-highlight">
                    <i class="fas fa-shield-alt"></i>
                    <span>100% Safe & Certified</span> - All our products meet strict safety standards
                </div>
            </div>
            <div class="hero-image">
                <div class="hero-image-content">
                    <i class="fas fa-star"></i>
                    <h3>10+ Years</h3>
                    <p>of Safe Celebrations</p>
                </div>
            </div>
        </div>

        <!-- Simple Stats -->
        <div class="simple-stats">
            <div class="stat-item">
                <i class="fas fa-users"></i>
                <span class="stat-number">50K+</span>
                <span class="stat-label">Happy Customers</span>
            </div>
            <div class="stat-item">
                <i class="fas fa-calendar"></i>
                <span class="stat-number">10+</span>
                <span class="stat-label">Years Experience</span>
            </div>
            <div class="stat-item">
                <i class="fas fa-map-marker-alt"></i>
                <span class="stat-number">5+</span>
                <span class="stat-label">Showrooms</span>
            </div>
        </div>

        <!-- Values Section -->
        <div class="values-section">
            <h3 class="section-title">
                <i class="fas fa-chevron-right"></i>
                Why Choose Us
                <i class="fas fa-chevron-left"></i>
            </h3>
            <div class="values-grid">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h4>Safety First</h4>
                    <p>All products tested and certified for safe use</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-medal"></i>
                    </div>
                    <h4>Premium Quality</h4>
                    <p>Best materials for spectacular effects</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-truck"></i>
                    </div>
                    <h4>Fast Delivery</h4>
                    <p>5-7 business days across India</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-rupee-sign"></i>
                    </div>
                    <h4>Best Prices</h4>
                    <p>Direct from manufacturer savings</p>
                </div>
            </div>
        </div>

        <!-- Safety Guidelines - Important for cracker site -->
        <div class="safety-section">
            <h3>
                <i class="fas fa-exclamation-triangle"></i>
                Safety Guidelines
            </h3>
            <div class="safety-grid">
                <div class="safety-item">
                    <i class="fas fa-check-circle"></i>
                    <p>Always keep water nearby while lighting crackers</p>
                </div>
                <div class="safety-item">
                    <i class="fas fa-check-circle"></i>
                    <p>Light only in open spaces, away from buildings</p>
                </div>
                <div class="safety-item">
                    <i class="fas fa-check-circle"></i>
                    <p>Never relight a dud - soak it in water and dispose</p>
                </div>
                <div class="safety-item">
                    <i class="fas fa-check-circle"></i>
                    <p>Adults should supervise children at all times</p>
                </div>
            </div>
        </div>

        <!-- Simple CTA -->
        <div class="about-cta">
            <h3>Ready to Light Up Your Celebration?</h3>
            <p>Browse our collection of premium crackers for every occasion</p>
            <div class="cta-buttons">
                <a href="/#products" class="btn btn-primary">
                    <i class="fas fa-shopping-cart"></i>
                    Shop Now
                </a>
                <a href="/contact" class="btn btn-outline">
                    <i class="fas fa-envelope"></i>
                    Contact Us
                </a>
            </div>
        </div>
    </div>

    <%- include('../partials/user/footer') %>
</body>
</html>