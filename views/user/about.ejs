<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>About Us - Artemis Crakers</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700,800" rel="stylesheet">
    
    <!-- CRITICAL FIX: Header alignment reset for mobile devices -->
    <style>
        /* === Header & Navbar Mobile Alignment Fixes === */
        /* Reset any inherited styles that could break header layout on mobile */
        body {
            overflow-x: hidden;
            width: 100%;
            margin: 0;
            padding: 0;
        }

        /* Ensure navbar container uses proper Bootstrap spacing without interference */
        .navbar {
            width: 100%;
            margin: 0 !important;
            padding: 0.5rem 1rem !important;
            background-color: #fff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        /* Fix navbar container responsiveness */
        .navbar .container,
        .navbar .container-fluid {
            padding-left: 15px !important;
            padding-right: 15px !important;
            width: 100%;
            max-width: 100%;
            margin: 0 auto;
        }

        /* Ensure navbar brand (logo) alignment on all screens */
        .navbar-brand {
            display: inline-flex;
            align-items: center;
            font-size: 1.4rem;
            white-space: normal;
            line-height: 1.2;
            padding: 0;
        }

        /* Fix navbar toggler button position and spacing */
        .navbar-toggler {
            border: 1px solid #ddd;
            margin: 0;
            padding: 0.4rem 0.75rem;
            outline: none;
            box-shadow: none;
        }

        /* Mobile nav items alignment */
        @media (max-width: 767px) {
            .navbar-collapse {
                padding-top: 12px;
                padding-bottom: 8px;
                text-align: center;
                background-color: #fff;
                border-radius: 8px;
                margin-top: 8px;
            }
            
            .navbar-nav {
                margin: 0 !important;
                padding: 0 !important;
                text-align: center;
                width: 100%;
            }
            
            .navbar-nav .nav-item {
                margin: 6px 0;
                text-align: center;
            }
            
            .navbar-nav .nav-link {
                display: inline-block;
                padding: 6px 12px;
                text-align: center;
            }
            
            /* Fix any absolute positioned icons or cart in header */
            .navbar .fa-shopping-cart,
            .navbar .fa-user,
            .navbar .fa-heart {
                margin-right: 4px;
            }
            
            /* Ensure header doesn't overflow */
            .navbar-brand img {
                max-height: 40px;
                width: auto;
            }
        }
        
        /* Medium screen adjustments */
        @media (min-width: 768px) and (max-width: 991px) {
            .navbar-nav .nav-link {
                padding: 8px 12px;
            }
        }
        
        /* Prevent any global margin/padding from affecting header layout */
        header, .header, .navbar, .navbar * {
            box-sizing: border-box;
        }
        
        /* Fix for sticky/fixed headers if any - ensures content doesn't hide under header */
        body:not(.no-header-fix) {
            padding-top: 0 !important;
        }
        
        /* Additional insurance: no unwanted transforms on header elements */
        .navbar-brand, .navbar-toggler, .nav-link {
            transition: none;
        }
    </style>
    
    <!-- About Page Styles (fully scoped & non-conflicting) -->
    <style>
        /* All about-page styles remain contained, no global header conflicts */
        .about-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 20px 15px;
        }

        .about-header {
            text-align: center;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid #ff6b35;
        }

        .about-title {
            font-size: 2rem;
            font-weight: 700;
            color: #2b2d42;
            margin-bottom: 5px;
        }

        .about-title i {
            color: #ff6b35;
            margin: 0 8px;
            font-size: 1.8rem;
        }

        .about-subtitle {
            color: #666;
            font-size: 1rem;
        }

        .about-hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 30px;
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .hero-content {
            padding: 30px;
        }

        .hero-content h2 {
            font-size: 1.6rem;
            font-weight: 600;
            color: #2b2d42;
            margin-bottom: 15px;
        }

        .hero-content h2 i {
            color: #ff6b35;
            margin-right: 8px;
        }

        .hero-content p {
            color: #555;
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 15px;
        }

        .hero-highlight {
            background: rgba(255, 107, 53, 0.1);
            border-left: 4px solid #ff6b35;
            padding: 12px 15px;
            border-radius: 0 4px 4px 0;
            margin-top: 20px;
        }

        .hero-highlight i {
            color: #ff6b35;
            margin-right: 8px;
        }

        .hero-highlight span {
            font-weight: 600;
            color: #e53e3e;
        }

        .hero-image {
            background: linear-gradient(135deg, #1a1b2f 0%, #2a2c4a 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .hero-image::before {
            content: '🎆 🎇 ✨ 🎆 🎇';
            position: absolute;
            font-size: 4rem;
            opacity: 0.1;
            white-space: nowrap;
            animation: moveStars 20s linear infinite;
        }

        @keyframes moveStars {
            from { transform: translateX(-100%); }
            to { transform: translateX(100%); }
        }

        .hero-image-content {
            text-align: center;
            z-index: 1;
        }

        .hero-image-content i {
            font-size: 4rem;
            color: #ffd93d;
            margin-bottom: 15px;
            display: block;
        }

        .hero-image-content h3 {
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, #ff6b35, #ffd93d);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        .simple-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
            text-align: center;
        }

        .stat-item {
            background: white;
            padding: 20px;
            border-radius: 6px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.03);
            border: 1px solid #eee;
        }

        .stat-item i {
            font-size: 2rem;
            color: #ff6b35;
            margin-bottom: 8px;
        }

        .stat-number {
            font-size: 1.8rem;
            font-weight: 700;
            color: #2b2d42;
            display: block;
        }

        .stat-label {
            color: #666;
            font-size: 0.9rem;
        }

        .values-section {
            margin-bottom: 30px;
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: #2b2d42;
            margin-bottom: 20px;
            text-align: center;
        }

        .section-title i {
            color: #ff6b35;
            margin: 0 8px;
        }

        .values-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
        }

        .value-card {
            background: white;
            padding: 20px;
            border-radius: 6px;
            border: 1px solid #eee;
            text-align: center;
            transition: transform 0.3s;
        }

        .value-card:hover {
            transform: translateY(-3px);
            border-color: #ff6b35;
        }

        .value-icon {
            width: 50px;
            height: 50px;
            background: rgba(255, 107, 53, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            color: #ff6b35;
            font-size: 1.3rem;
        }

        .value-card h4 {
            font-size: 1rem;
            font-weight: 600;
            color: #2b2d42;
            margin-bottom: 8px;
        }

        .value-card p {
            color: #666;
            font-size: 0.85rem;
            line-height: 1.4;
            margin: 0;
        }

        .safety-section {
            background: linear-gradient(135deg, #fff5f0 0%, #fff0e6 100%);
            border-radius: 8px;
            padding: 25px;
            margin-bottom: 30px;
            border: 1px solid #ffd1b3;
        }

        .safety-section h3 {
            color: #e53e3e;
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .safety-section h3 i {
            margin-right: 10px;
        }

        .safety-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .safety-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }

        .safety-item i {
            color: #ff6b35;
            font-size: 1.1rem;
            margin-top: 2px;
        }

        .safety-item p {
            margin: 0;
            color: #555;
            font-size: 0.9rem;
        }

        .about-cta {
            text-align: center;
            padding: 30px;
            background: #f8f9fa;
            border-radius: 6px;
            border: 1px solid #eee;
        }

        .about-cta h3 {
            font-size: 1.4rem;
            font-weight: 600;
            color: #2b2d42;
            margin-bottom: 10px;
        }

        .about-cta p {
            color: #666;
            margin-bottom: 20px;
        }

        .cta-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
        }

        .btn {
            padding: 10px 25px;
            border-radius: 4px;
            font-weight: 500;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
        }

        .btn-primary {
            background: #ff6b35;
            color: white;
            border: none;
        }

        .btn-primary:hover {
            background: #e55a2b;
            transform: translateY(-2px);
        }

        .btn-outline {
            border: 1px solid #ddd;
            color: #2b2d42;
            background: white;
        }

        .btn-outline:hover {
            background: #f5f5f5;
        }

        /* About page responsive styles (no header interference) */
        @media (max-width: 991px) {
            .about-container {
                max-width: 720px;
            }
            .values-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 15px;
            }
        }

        @media (max-width: 767px) {
            .about-container {
                padding: 15px 12px;
            }
            .about-title {
                font-size: 1.6rem;
            }
            .about-hero {
                grid-template-columns: 1fr;
                gap: 0;
            }
            .hero-content {
                padding: 20px;
                order: 1;
            }
            .hero-image {
                padding: 30px 20px;
                order: 0;
            }
            .simple-stats {
                grid-template-columns: 1fr;
                gap: 12px;
            }
            .stat-item {
                padding: 15px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                text-align: left;
            }
            .values-grid {
                grid-template-columns: 1fr;
                gap: 12px;
            }
            .value-card {
                padding: 15px;
                display: flex;
                align-items: center;
                text-align: left;
                gap: 15px;
            }
            .value-icon {
                margin: 0;
                width: 45px;
                height: 45px;
                flex-shrink: 0;
            }
            .safety-section {
                padding: 18px;
            }
            .safety-grid {
                grid-template-columns: 1fr;
                gap: 12px;
            }
            .about-cta {
                padding: 20px;
            }
            .cta-buttons {
                flex-direction: column;
                align-items: center;
                gap: 10px;
            }
            .btn {
                width: 100%;
                max-width: 220px;
                justify-content: center;
            }
        }

        @media (max-width: 480px) {
            .about-title {
                font-size: 1.4rem;
            }
            .hero-content h2 {
                font-size: 1.2rem;
            }
        }
    </style>
</head>

<body>
    <!-- Header included exactly as in Contact Us page (now mobile-alignment fixed) -->
    <%- include('../partials/user/header') %>

    <!-- About Page Content (fully independent, no header style leakage) -->
    <div class="about-container">
        <div class="about-header">
            <h1 class="about-title">
                <i class="fas fa-star"></i>
                About Artemis Crakers
                <i class="fas fa-star"></i>
            </h1>
            <p class="about-subtitle">Lighting up celebrations since 2015</p>
        </div>

        <div class="about-hero">
            <div class="hero-content">
                <h2>
                    <i class="fas fa-fire"></i>
                    Our Story
                </h2>
                <p>
                    Founded in 2015, Artemis Crakers started with a simple mission: to bring safe, 
                    high-quality fireworks to every celebration. What began as a small family workshop 
                    in Chennai has grown into one of South India's most trusted cracker brands.
                </p>
                <p>
                    We combine traditional craftsmanship with modern safety standards to create 
                    fireworks that light up your special moments. From Diwali to weddings, our 
                    products have been part of countless happy celebrations.
                </p>
                <div class="hero-highlight">
                    <i class="fas fa-shield-alt"></i>
                    <span>100% Safe & Certified</span> - All our products meet strict safety standards
                </div>
            </div>
            <div class="hero-image">
                <div class="hero-image-content">
                    <i class="fas fa-star"></i>
                    <h3>10+ Years</h3>
                    <p>of Safe Celebrations</p>
                </div>
            </div>
        </div>

        <div class="simple-stats">
            <div class="stat-item">
                <i class="fas fa-users"></i>
                <span class="stat-number">50K+</span>
                <span class="stat-label">Happy Customers</span>
            </div>
            <div class="stat-item">
                <i class="fas fa-calendar"></i>
                <span class="stat-number">10+</span>
                <span class="stat-label">Years Experience</span>
            </div>
            <div class="stat-item">
                <i class="fas fa-map-marker-alt"></i>
                <span class="stat-number">5+</span>
                <span class="stat-label">Showrooms</span>
            </div>
        </div>

        <div class="values-section">
            <h3 class="section-title">
                <i class="fas fa-chevron-right"></i>
                Why Choose Us
                <i class="fas fa-chevron-left"></i>
            </h3>
            <div class="values-grid">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h4>Safety First</h4>
                    <p>All products tested and certified for safe use</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-medal"></i>
                    </div>
                    <h4>Premium Quality</h4>
                    <p>Best materials for spectacular effects</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-truck"></i>
                    </div>
                    <h4>Fast Delivery</h4>
                    <p>5-7 business days across India</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fas fa-rupee-sign"></i>
                    </div>
                    <h4>Best Prices</h4>
                    <p>Direct from manufacturer savings</p>
                </div>
            </div>
        </div>

        <div class="safety-section">
            <h3>
                <i class="fas fa-exclamation-triangle"></i>
                Safety Guidelines
            </h3>
            <div class="safety-grid">
                <div class="safety-item">
                    <i class="fas fa-check-circle"></i>
                    <p>Always keep water nearby while lighting crackers</p>
                </div>
                <div class="safety-item">
                    <i class="fas fa-check-circle"></i>
                    <p>Light only in open spaces, away from buildings</p>
                </div>
                <div class="safety-item">
                    <i class="fas fa-check-circle"></i>
                    <p>Never relight a dud - soak it in water and dispose</p>
                </div>
                <div class="safety-item">
                    <i class="fas fa-check-circle"></i>
                    <p>Adults should supervise children at all times</p>
                </div>
            </div>
        </div>

        <div class="about-cta">
            <h3>Ready to Light Up Your Celebration?</h3>
            <p>Browse our collection of premium crackers for every occasion</p>
            <div class="cta-buttons">
                <a href="/#products" class="btn btn-primary">
                    <i class="fas fa-shopping-cart"></i>
                    Shop Now
                </a>
                <a href="/contact" class="btn btn-outline">
                    <i class="fas fa-envelope"></i>
                    Contact Us
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%- include('../partials/user/footer') %>
</body>
</html>