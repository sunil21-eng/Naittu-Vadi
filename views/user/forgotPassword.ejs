<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>
    <!-- The CSS is embedded here to create a self-contained document -->
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background-color: #fff;
            color: #111;
        }

        header {
            padding: 1rem 2rem;
            border-bottom: 1px solid #eee;
        }

        .logo {
            font-weight: bold;
            font-size: 1.2rem;
        }

        .container {
            max-width: 500px;
            margin: 5rem auto;
            padding: 1rem;
            text-align: center;
        }

        h2 {
            font-weight: bold;
            margin-bottom: 1rem;
        }

        p {
            color: #666;
            margin-bottom: 2rem;
        }

        form {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }

        input[type="email"] {
            width: 100%;
            max-width: 350px;
            padding: 0.8rem;
            border-radius: 8px;
            border: 1px solid #ddd;
            font-size: 0.9rem;
            text-align: left;
        }

        .btn-primary {
            background-color: #4a60e0;
            color: white;
            padding: 0.8rem 2rem;
            border: none;
            border-radius: 20px;
            font-size: 0.9rem;
            cursor: pointer;
            width: 100%;
            max-width: 350px;
        }

        .btn-primary:hover {
            background-color: #3c4bb8;
        }

        .signin-link {
            font-size: 0.85rem;
            margin-top: 1rem;
        }

        .signin-link a {
            color: #4a60e0;
            text-decoration: none;
        }
    </style>
</head>

<body>

    <!-- This is the header section -->
    <header>
        <div class="logo">Artemis</div>
    </header>

    <!-- The main content and form are in this section -->
    <main>
        <div class="container">
            <h2>Forgot your password?</h2>
            <p>Enter the email address associated with your account, and we'll send you a link to reset your password.
            </p>

            <% if (typeof error !=="undefined" ) { %>
                <p style="color: red;">
                    <%= error %>
                </p>
                <% } %>
                    <form action="/forgotPassword" method="POST">
                        <input type="email" name="email" placeholder="Email" required>
                        <button type="submit" class="btn-primary">Send OTP</button>
                    </form>
                    <p class="signin-link">Remember your password? <a href="/login">Sign In</a></p>
        </div>
    </main>

</body>

</html>