<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Contact Us - Artemis Crakers</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700,800" rel="stylesheet">
    <style>
        /* ========== GLOBAL RESET & BASE STYLES ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            background-color: #fff;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* ========== CONTACT PAGE STYLES (FULLY RESPONSIVE, NO CONTENT CHANGED) ========== */
        :root {
            --primary-color: #3a86ff;
            --dark-color: #2b2d42;
            --light-color: #f8f9fa;
            --border-color: #dee2e6;
            --cracker-orange: #ff6b35;
            --cracker-gold: #ffd93d;
            --cracker-red: #e53e3e;
        }

        .contact-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px 15px;
        }

        /* Simple Header */
        .contact-header {
            text-align: center;
            margin-bottom: 25px;
        }

        .contact-title {
            font-size: 2rem;
            font-weight: 700;
            color: var(--dark-color);
            margin-bottom: 5px;
        }

        .contact-title i {
            color: var(--cracker-orange);
            margin: 0 8px;
        }

        .contact-subtitle {
            color: #666;
            font-size: 1rem;
        }

        /* Contact Info Cards - Full Width */
        .contact-info-card {
            background: white;
            border-radius: 8px;
            padding: 25px;
            border: 1px solid #eee;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
            margin-bottom: 25px;
        }

        .info-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--cracker-orange);
        }

        .info-header i {
            color: var(--cracker-orange);
            font-size: 1.3rem;
        }

        .info-header h3 {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--dark-color);
            margin: 0;
        }

        /* Contact Methods - Grid Layout */
        .contact-methods {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 25px;
        }

        .method-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            background: #fafafa;
            border-radius: 6px;
            transition: all 0.3s;
        }

        .method-item:hover {
            background: #f0f0f0;
            transform: translateY(-2px);
        }

        .method-icon {
            width: 40px;
            height: 40px;
            background: rgba(255, 107, 53, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--cracker-orange);
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .method-details {
            flex: 1;
        }

        .method-details .label {
            font-size: 0.8rem;
            color: #888;
            margin-bottom: 2px;
        }

        .method-details .value {
            font-weight: 500;
            color: #333;
            font-size: 0.95rem;
        }

        .method-details .value a {
            color: #333;
            text-decoration: none;
        }

        .method-details .value a:hover {
            color: var(--cracker-orange);
        }

        /* Address Section */
        .address-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 25px;
        }

        .address-card {
            padding: 15px;
            background: #fafafa;
            border-radius: 6px;
            border-left: 3px solid var(--cracker-orange);
        }

        .address-card i {
            color: var(--cracker-orange);
            margin-right: 8px;
        }

        .address-card h4 {
            font-size: 1rem;
            font-weight: 600;
            color: var(--dark-color);
            margin: 0 0 8px 0;
        }

        .address-card p {
            color: #666;
            font-size: 0.9rem;
            margin: 0;
            line-height: 1.5;
        }

        /* Business Hours */
        .hours-section {
            margin-top: 25px;
        }

        .hours-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .hours-row {
            display: flex;
            justify-content: space-between;
            font-size: 0.95rem;
            padding: 8px 0;
            border-bottom: 1px dashed #eee;
        }

        .hours-row .day {
            color: #666;
        }

        .hours-row .time {
            font-weight: 500;
            color: #333;
        }

        .hours-row.closed .time {
            color: var(--cracker-red);
        }

        /* Map Section - Simple */
        .map-section {
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #eee;
        }

        .map-placeholder {
            background: linear-gradient(135deg, #2b2d42 0%, #1a1b2f 100%);
            padding: 25px;
            text-align: center;
            color: white;
        }

        .map-placeholder i {
            font-size: 2.5rem;
            color: var(--cracker-gold);
            margin-bottom: 10px;
        }

        .map-placeholder p {
            margin: 0;
            font-size: 0.95rem;
        }

        .map-placeholder .address {
            font-size: 1.1rem;
            font-weight: 600;
            margin: 5px 0;
            color: var(--cracker-gold);
        }

        /* ========== FULLY RESPONSIVE STYLES - MOBILE & DESKTOP ========== */
        /* Desktop (992px - 1199px) - subtle adjustments */
        @media (max-width: 1199px) {
            .contact-container {
                max-width: 750px;
                padding: 20px 15px;
            }
        }

        /* Tablet (768px - 991px) - reflow but keep all content */
        @media (max-width: 991px) {
            .contact-container {
                max-width: 90%;
                padding: 20px 15px;
            }
            .contact-methods {
                gap: 15px;
            }
            .address-section {
                gap: 15px;
            }
        }

        /* Mobile (up to 767px) - full stacking, no content loss */
        @media (max-width: 767px) {
            .contact-container {
                padding: 15px 12px;
                max-width: 100%;
            }
            
            .contact-title {
                font-size: 1.6rem;
            }
            
            .contact-title i {
                font-size: 1.3rem;
                margin: 0 5px;
            }
            
            .contact-subtitle {
                font-size: 0.9rem;
            }
            
            .contact-info-card {
                padding: 18px;
            }
            
            .info-header {
                margin-bottom: 15px;
            }
            
            .info-header i {
                font-size: 1.1rem;
            }
            
            .info-header h3 {
                font-size: 1.1rem;
            }
            
            /* Contact methods stack vertically on mobile */
            .contact-methods {
                grid-template-columns: 1fr;
                gap: 12px;
                margin-bottom: 20px;
            }
            
            .method-item {
                padding: 10px;
                gap: 10px;
            }
            
            .method-icon {
                width: 35px;
                height: 35px;
                font-size: 1rem;
            }
            
            .method-details .label {
                font-size: 0.75rem;
            }
            
            .method-details .value {
                font-size: 0.85rem;
            }
            
            /* Address section stacks vertically */
            .address-section {
                grid-template-columns: 1fr;
                gap: 12px;
                margin-bottom: 20px;
            }
            
            .address-card {
                padding: 12px;
            }
            
            .address-card h4 {
                font-size: 0.95rem;
            }
            
            .address-card p {
                font-size: 0.85rem;
            }
            
            /* Business hours responsive */
            .hours-section {
                margin-top: 20px;
            }
            
            .hours-row {
                flex-direction: column;
                text-align: center;
                gap: 5px;
                padding: 8px 0;
            }
            
            .hours-row .day {
                font-weight: 600;
            }
            
            .hours-row .time {
                font-size: 0.9rem;
            }
            
            /* Map section responsive */
            .map-placeholder {
                padding: 20px;
            }
            
            .map-placeholder i {
                font-size: 2rem;
            }
            
            .map-placeholder .address {
                font-size: 0.95rem;
            }
            
            .map-placeholder p {
                font-size: 0.85rem;
            }
        }

        /* Extra small devices (480px and below) - fine-tuning */
        @media (max-width: 480px) {
            .contact-container {
                padding: 12px 10px;
            }
            
            .contact-title {
                font-size: 1.4rem;
            }
            
            .contact-title i {
                font-size: 1.1rem;
                margin: 0 3px;
            }
            
            .contact-subtitle {
                font-size: 0.85rem;
            }
            
            .contact-info-card {
                padding: 15px;
            }
            
            .info-header {
                margin-bottom: 12px;
                gap: 8px;
            }
            
            .info-header i {
                font-size: 1rem;
            }
            
            .info-header h3 {
                font-size: 1rem;
            }
            
            .method-item {
                padding: 8px;
                gap: 8px;
            }
            
            .method-icon {
                width: 32px;
                height: 32px;
                font-size: 0.9rem;
            }
            
            .method-details .label {
                font-size: 0.7rem;
            }
            
            .method-details .value {
                font-size: 0.8rem;
            }
            
            .address-card {
                padding: 10px;
            }
            
            .address-card h4 {
                font-size: 0.9rem;
                margin-bottom: 5px;
            }
            
            .address-card p {
                font-size: 0.8rem;
            }
            
            .hours-row {
                padding: 6px 0;
            }
            
            .hours-row .day {
                font-size: 0.85rem;
            }
            
            .hours-row .time {
                font-size: 0.85rem;
            }
            
            .map-placeholder {
                padding: 15px;
            }
            
            .map-placeholder i {
                font-size: 1.8rem;
            }
            
            .map-placeholder .address {
                font-size: 0.85rem;
            }
            
            .map-placeholder p {
                font-size: 0.8rem;
            }
        }

        /* Ensure all links and interactive elements remain functional */
        .method-details .value a {
            transition: color 0.3s;
        }
        
        .method-details .value a:active {
            color: var(--cracker-orange);
        }
        
        /* Preserve all hover effects on larger screens */
        @media (min-width: 768px) {
            .method-item:hover {
                background: #f0f0f0;
                transform: translateY(-2px);
            }
        }
        
        /* No horizontal scroll on any device */
        .contact-container,
        .contact-info-card,
        .contact-methods,
        .address-section,
        .map-section {
            overflow-x: hidden;
        }
        
        /* Fix for pincode tag display */
        pincode\-\> {
            display: inline;
        }
    </style>
</head>
<body>
    <%- include('../partials/user/header') %>

    <div class="contact-container">
        <!-- Simple Header -->
        <div class="contact-header">
            <h1 class="contact-title">
                <i class="fas fa-star"></i>
                Contact Us
                <i class="fas fa-star"></i>
            </h1>
            <p class="contact-subtitle">Get in touch with us for all your celebration needs!</p>
        </div>

        <!-- Main Contact Card -->
        <div class="contact-info-card">
            <div class="info-header">
                <i class="fas fa-fire"></i>
                <h3>Get in Touch</h3>
            </div>
            
            <!-- Contact Methods Grid -->
            <div class="contact-methods">
                <!-- Phone -->
                <div class="method-item">
                    <div class="method-icon">
                        <i class="fas fa-phone-alt"></i>
                    </div>
                    <div class="method-details">
                        <div class="label">Call Us</div>
                        <div class="value">
                            <a href="tel:+917868829460">+91 78688 29460</a>
                        </div>
                    </div>
                </div>

                <!-- Email -->
                <div class="method-item">
                    <div class="method-icon">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <div class="method-details">
                        <div class="label">Email Us</div>
                        <div class="value">
                            <a href="mailto:opensurfaces21@gmail.com">opensurfaces21@gmail.com</a>
                        </div>
                    </div>
                </div>

                <!-- WhatsApp -->
                <div class="method-item">
                    <div class="method-icon">
                        <i class="fab fa-whatsapp"></i>
                    </div>
                    <div class="method-details">
                        <div class="label">WhatsApp</div>
                        <div class="value">
                            <a href="https://wa.me/917868829460">+91 78688 29460</a>
                        </div>
                    </div>
                </div>

                <!-- Hours Note -->
                <div class="method-item">
                    <div class="method-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <div class="method-details">
                        <div class="label">Quick Response</div>
                        <div class="value">Within 24 hours</div>
                    </div>
                </div>
            </div>

            <!-- Address Section -->
            <div class="address-section">
                <div class="address-card">
                    <h4><i class="fas fa-building"></i> Main Office</h4>
                    <p>Dharmaraja nagar,<br>Singarapettai, Krishnagiri <br>Tamil Nadu,India, <pincode->635307</pincode-></p>
                </div>
                <div class="address-card">
                    <h4><i class="fas fa-warehouse"></i> Factory & Showroom</h4>
                    <p>Dharmaraja nagar,<br>Singarapettai, Krishnagiri <br>Tamil Nadu,India, <pincode->635307</pincode-></p>
                </div>
            </div>

            <!-- Business Hours -->
            <div class="hours-section">
                <div class="info-header" style="margin-bottom: 15px;">
                    <i class="fas fa-clock"></i>
                    <h3>Business Hours</h3>
                </div>
                <div class="hours-list">
                    <div class="hours-row">
                        <span class="day">Monday - Saturday</span>
                        <span class="time">9:00 AM - 8:00 PM</span>
                    </div>
                    <div class="hours-row">
                        <span class="day">Sunday</span>
                        <span class="time">10:00 AM - 2:00 PM</span>
                    </div>
                    <div class="hours-row closed">
                        <span class="day">Public Holidays</span>
                        <span class="time">Closed</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Simple Map Section -->
        <div class="map-section">
            <div class="map-placeholder">
                <i class="fas fa-map-marked-alt"></i>
                <p class="address">Dharmaraja nagar, Singarapettai, Krishnagiri - 635307</p>
                <p>Visit our main showroom for festival special offers!</p>
                <p style="font-size: 0.85rem; margin-top: 10px;">
                    <i class="fas fa-train"></i> Nearest Station: Samalpatti (18 km)
                </p>
            </div>
        </div>
    </div>

    <%- include('../partials/user/footer') %>
</body>
</html>