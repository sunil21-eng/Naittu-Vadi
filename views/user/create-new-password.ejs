<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Password</title>
    <!-- The CSS is embedded here to create a self-contained document -->
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background-color: #fff;
            color: #111;
        }

        header {
            padding: 1rem 2rem;
            border-bottom: 1px solid #eee;
        }
        
        .logo {
            font-weight: bold;
            font-size: 1.2rem;
        }

        .container {
            max-width: 500px;
            margin: 5rem auto;
            padding: 1rem;
            text-align: center;
        }

        h2 {
            font-weight: bold;
            margin-bottom: 1rem;
        }

        .subtitle {
            color: #666;
            margin-bottom: 2rem;
        }
        
        form {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }
        
        .input-group {
            width: 100%;
            max-width: 350px;
            text-align: left;
        }

        .input-group label {
            font-size: 0.9rem;
            font-weight: bold;
            color: #111;
            display: block;
            margin-bottom: 0.5rem;
        }

        .input-group input {
            width: 100%;
            padding: 0.8rem;
            border-radius: 8px;
            border: 1px solid #ddd;
            font-size: 0.9rem;
        }

        .password-info {
            font-size: 0.85rem;
            color: #666;
            text-align: left;
            width: 100%;
            max-width: 350px;
            margin-top: 1rem;
        }

        .btn-primary {
            background-color: #4a60e0;
            color: white;
            padding: 0.8rem 2rem;
            border: none;
            border-radius: 20px;
            font-size: 0.9rem;
            cursor: pointer;
            width: 100%;
            max-width: 350px;
            margin-top: 1rem;
        }

        .btn-primary:hover {
            background-color: #3c4bb8;
        }
    </style>
</head>
<body>

    <!-- This is the header section -->
    <header>
        <div class="logo">Artemis</div>
    </header>

    <!-- The main content and form are in this section -->
    <main>
        <div class="container">
            <h2>Create New Password</h2>
            <p class="subtitle">Your new password must be different from previously used passwords.</p>
            <form action="/reset-password" method="POST">
                <div class="input-group">
                    <label for="newPassword">New Password</label>
                    <input type="password" id="newPassword" name="newPassword" placeholder="Enter new password" required>
                </div>
                
                <div class="input-group">
                    <label for="confirmPassword">Confirm New Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm new password" required>
                </div>

                <p class="password-info">
                    Password must be at least 8 characters long and include at least one uppercase letter, one lowercase letter, one number, and one special character.
                </p>
                
                <button type="submit" class="btn-primary">Change Password</button>
            </form>
        </div>
    </main>

</body>
</html>
