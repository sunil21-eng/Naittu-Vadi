<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Profile - AllScouts</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --primary-color: #3a86ff;
            --danger-color: #e63946;
            --success-color: #2a9d8f;
            --text-color: #333;
            --light-gray: #f8f9fa;
            --border-color: #dee2e6;
            --sidebar-bg: #2c3e50;
            --sidebar-active: #3498db;
        }
        
        * {
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-color);
            background-color: #fff;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }
        
        .profile-header {
            background-color: var(--light-gray);
            padding: 40px 0 25px;
            text-align: center;
            margin-bottom: 25px;
        }
        
        .profile-title {
            font-size: clamp(1.3rem, 5vw, 1.8rem);
            font-weight: 700;
            margin-bottom: 10px;
            padding: 0 15px;
        }
        
        .breadcrumb {
            justify-content: center;
            background: transparent;
            font-size: 0.85rem;
            margin-bottom: 0;
            flex-wrap: wrap;
        }
        
        .breadcrumb-item a {
            color: var(--primary-color);
            text-decoration: none;
        }
        
        .profile-container {
            display: flex;
            max-width: 98%;
            margin: 0 auto 25px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            overflow: hidden;
            min-height: 500px;
        }

        /* Sidebar Styles */
        .profile-sidebar {
            width: 220px;
            background-color: var(--sidebar-bg);
            color: white;
            padding: 20px 0;
            transition: transform 0.3s ease;
        }

        .profile-sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .profile-sidebar-menu li {
            margin: 0;
        }

        .profile-sidebar-menu a {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: #ecf0f1;
            text-decoration: none;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
            font-size: 0.9rem;
        }

        .profile-sidebar-menu a:hover {
            background-color: #34495e;
            color: white;
        }

        .profile-sidebar-menu a.profile-active {
            background-color: var(--sidebar-active);
            border-left-color: #2980b9;
            color: white;
        }

        .profile-sidebar-menu i {
            margin-right: 8px;
            width: 16px;
            text-align: center;
            font-size: 0.9rem;
        }

        .profile-logout {
            padding: 15px 20px;
            margin-top: 15px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        .profile-logout-btn {
            width: 100%;
            padding: 10px;
            background-color: var(--danger-color);
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 500;
            transition: background-color 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
        }

        .profile-logout-btn:hover {
            background-color: #c0392b;
        }

        .profile-logout-btn i {
            margin-right: 6px;
        }

        /* Main Content Styles */
        .profile-main-content {
            flex: 1;
            padding: 25px;
            min-width: 0;
        }

        .profile-page-title {
            font-size: clamp(1.3rem, 4vw, 1.5rem);
            margin-bottom: 5px;
            color: #2c3e50;
            font-weight: 600;
        }

        .profile-page-subtitle {
            color: #7f8c8d;
            margin-bottom: 20px;
            font-size: 0.9rem;
        }

        /* User Information Section */
        .profile-user-section {
            display: flex;
            align-items: flex-start;
            margin-bottom: 25px;
            padding: 20px;
            background: white;
            border-radius: 6px;
            box-shadow: 0 1px 5px rgba(0,0,0,0.05);
            border: 1px solid var(--border-color);
        }

        .profile-user-avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            overflow: hidden;
            margin-right: 20px;
            border: 2px solid #ecf0f1;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f8f9fa;
            flex-shrink: 0;
        }

        .profile-user-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-user-avatar svg {
            width: 40px;
            height: 40px;
            color: #bdc3c7;
        }

        .profile-user-info {
            flex: 1;
            min-width: 0;
        }

        .profile-user-name {
            font-size: clamp(1.1rem, 4vw, 1.3rem);
            margin: 0 0 15px 0;
            color: #2c3e50;
            font-weight: 600;
            word-break: break-word;
        }

        /* Properly aligned user details */
        .profile-user-details {
            margin-bottom: 15px;
        }

        .profile-user-detail-item {
            display: flex;
            align-items: baseline;
            margin-bottom: 12px;
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .profile-user-detail-label {
            font-weight: 600;
            color: #34495e;
            min-width: 110px;
            font-size: 0.95rem;
            display: inline-block;
        }

        .profile-user-detail-value {
            color: #2c3e50;
            word-break: break-word;
        }

        .profile-edit-link {
            display: inline-block;
            padding: 8px 20px;
            background-color: var(--primary-color);
            color: white;
            text-decoration: none;
            border-radius: 4px;
            font-weight: 500;
            transition: all 0.3s;
            font-size: 0.9rem;
            margin-top: 5px;
        }

        .profile-edit-link:hover {
            background-color: #2a75e6;
            color: white;
            transform: translateY(-1px);
        }

        /* Alert Styles */
        .alert {
            padding: 12px 15px;
            border-radius: 4px;
            margin-bottom: 20px;
            border: none;
            font-weight: 500;
            font-size: 0.9rem;
        }
        
        .alert-success {
            background-color: rgba(42, 157, 143, 0.1);
            color: var(--success-color);
            border-left: 3px solid var(--success-color);
        }
        
        .alert-danger {
            background-color: rgba(230, 57, 70, 0.1);
            color: var(--danger-color);
            border-left: 3px solid var(--danger-color);
        }

        /* Footer */
        footer {
            margin-top: 20px !important;
        }

        /* Responsive Styles */
        @media (max-width: 992px) {
            .profile-container {
                flex-direction: column;
                max-width: 95%;
            }
            
            .profile-sidebar {
                width: 100%;
                padding: 10px 0;
            }
            
            .profile-sidebar-menu {
                display: flex;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: thin;
                padding-bottom: 5px;
            }
            
            .profile-sidebar-menu::-webkit-scrollbar {
                height: 4px;
            }
            
            .profile-sidebar-menu::-webkit-scrollbar-thumb {
                background-color: rgba(255,255,255,0.3);
                border-radius: 4px;
            }
            
            .profile-sidebar-menu li {
                flex-shrink: 0;
            }
            
            .profile-sidebar-menu a {
                border-left: none;
                border-bottom: 3px solid transparent;
                white-space: nowrap;
                padding: 12px 15px;
            }
            
            .profile-sidebar-menu a.profile-active {
                border-left: none;
                border-bottom-color: #2980b9;
            }
            
            .profile-logout {
                padding: 10px 15px;
                margin-top: 10px;
            }
        }

        @media (max-width: 768px) {
            .profile-container {
                max-width: 100%;
                border-radius: 0;
                margin: 0 0 25px;
            }
            
            .profile-main-content {
                padding: 20px 15px;
            }
            
            .profile-header {
                padding: 30px 0 20px;
            }
            
            .profile-user-section {
                flex-direction: column;
                align-items: center;
                text-align: center;
                padding: 20px 15px;
            }
            
            .profile-user-avatar {
                margin-right: 0;
                margin-bottom: 20px;
                width: 120px;
                height: 120px;
            }
            
            .profile-user-info {
                width: 100%;
            }
            
            .profile-user-detail-item {
                flex-direction: column;
                align-items: flex-start;
                text-align: left;
                margin-bottom: 15px;
            }
            
            .profile-user-detail-label {
                min-width: auto;
                margin-bottom: 5px;
                font-size: 0.9rem;
            }
            
            .profile-user-detail-value {
                width: 100%;
                padding-left: 0;
            }
            
            .profile-edit-link {
                width: 100%;
                text-align: center;
                padding: 12px 20px;
            }
        }

        @media (max-width: 576px) {
            .profile-main-content {
                padding: 15px 12px;
            }
            
            .profile-header {
                padding: 25px 0 15px;
            }
            
            .profile-user-section {
                padding: 15px 12px;
                margin-bottom: 15px;
            }
            
            .profile-user-avatar {
                width: 100px;
                height: 100px;
            }
            
            .profile-page-title {
                margin-bottom: 8px;
            }
            
            .profile-page-subtitle {
                margin-bottom: 15px;
                font-size: 0.85rem;
            }
            
            .profile-sidebar-menu a {
                padding: 10px 12px;
                font-size: 0.85rem;
            }
            
            .profile-sidebar-menu i {
                margin-right: 6px;
                font-size: 0.85rem;
            }
            
            .profile-logout-btn {
                padding: 12px;
                font-size: 0.9rem;
            }
            
            .breadcrumb {
                font-size: 0.8rem;
                padding: 0 10px;
            }
        }

        @media (max-width: 480px) {
            .profile-user-detail-item {
                margin-bottom: 12px;
            }
            
            .profile-user-name {
                margin-bottom: 12px;
            }
            
            .alert {
                padding: 10px 12px;
                font-size: 0.85rem;
                margin-bottom: 15px;
            }
            
            footer p {
                font-size: 0.8rem !important;
                padding: 0 10px;
            }
        }

        /* Touch-friendly improvements */
        @media (hover: none) and (pointer: coarse) {
            .profile-sidebar-menu a,
            .profile-logout-btn,
            .profile-edit-link {
                min-height: 44px;
            }
            
            .profile-sidebar-menu a {
                padding: 14px 20px;
            }
        }

        /* Prevent horizontal scroll on very small devices */
        @media (max-width: 360px) {
            .profile-main-content {
                padding: 12px 10px;
            }
            
            .profile-user-section {
                padding: 12px 10px;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/user/header') %>

    <!-- Profile Header -->
    <section class="profile-header">
        <div class="container">
            <h1 class="profile-title">My Profile</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Profile</li>
                </ol>
            </nav>
        </div>
    </section>

    <!-- Profile Content -->
    <div class="profile-container">
        <!-- Sidebar -->
        <aside class="profile-sidebar">
            <ul class="profile-sidebar-menu">
                <li><a href="/profile" class="profile-active"><i class="fas fa-user"></i> Profile</a></li>
                <li><a href="/my-orders"><i class="fas fa-shopping-bag"></i> Orders</a></li>
                <li><a href="/addresses"><i class="fas fa-map-marker-alt"></i> Addresses</a></li>
                <li><a href="/wallet"><i class="fas fa-wallet"></i> Wallet</a></li>
                <li><a href="/changePassword"><i class="fas fa-key"></i> Change Password</a></li>
            </ul>
            <div class="profile-logout">
                <button class="profile-logout-btn" id="logoutBtn">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="profile-main-content">
            <h1 class="profile-page-title">Profile</h1>
            <p class="profile-page-subtitle">Manage your account information and preferences</p>

            <% if (messages && messages.success && messages.success.length > 0) { %>
                <div class="alert alert-success" role="alert"><%= messages.success[0] %></div>
            <% } %>
            <% if (messages && messages.error && messages.error.length > 0) { %>
                <div class="alert alert-danger" role="alert"><%= messages.error[0] %></div>
            <% } %>

            <!-- User Information Section -->
            <div class="profile-user-section">
                <div class="profile-user-avatar">
                    <% if (user.profileImage && user.profileImage.length > 0) { %>
                        <img src="<%= user.profileImage && user.profileImage[0] ? user.profileImage[0] : '/images/default-profile.jpg' %>" alt="Profile Image">
                    <% } else { %>
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" aria-label="Default profile avatar">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                        </svg>
                    <% } %>
                </div>
                <div class="profile-user-info">
                    <h2 class="profile-user-name"><%= user.firstName ? user.firstName + ' ' + (user.lastName || '') : 'N/A' %></h2>
                    
                    <!-- Properly aligned user details -->
                    <div class="profile-user-details">
                        <div class="profile-user-detail-item">
                            <span class="profile-user-detail-label">Email:</span>
                            <span class="profile-user-detail-value"><%= user.email || 'N/A' %></span>
                        </div>
                        <div class="profile-user-detail-item">
                            <span class="profile-user-detail-label">Phone:</span>
                            <span class="profile-user-detail-value"><%= user.phone || 'N/A' %></span>
                        </div>
                        <div class="profile-user-detail-item">
                            <span class="profile-user-detail-label">Date of Birth:</span>
                            <span class="profile-user-detail-value"><%= user.dob ? new Date(user.dob).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'N/A' %></span>
                        </div>
                    </div>
                    
                    <div>
                        <a href="/editProfile" class="profile-edit-link">Edit Profile</a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Footer Section -->
    <footer class="bg-light py-3 mt-3">
        <div class="container text-center">
            <p class="mb-0" style="font-size: 0.85rem;">&copy; 2023 Your Store. All rights reserved.</p>
        </div>
    </footer>

    <script>
        // Logout functionality
        document.getElementById('logoutBtn').addEventListener('click', async () => {
            try {
                // Send logout request
                const res = await fetch('/logout', { method: 'POST' });

                if (res.ok) {
                    // Redirect to home page instead of login
                    window.location.href = '/';
                } else {
                    console.error('Logout failed');
                }
            } catch (error) {
                console.error('Error during logout:', error);
            }
        });

        // Sidebar navigation highlighting
        document.addEventListener('DOMContentLoaded', function() {
            const currentPage = window.location.pathname;
            const sidebarLinks = document.querySelectorAll('.profile-sidebar-menu a');
            
            sidebarLinks.forEach(link => {
                link.classList.remove('profile-active');
                if (link.getAttribute('href') === currentPage) {
                    link.classList.add('profile-active');
                }
            });
        });
    </script>
</body>
</html>
<%- include('../partials/user/footer') %>