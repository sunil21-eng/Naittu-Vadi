<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Coupon - Admin</title>
    <style>
        /* General body and layout styling */
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7f9;
            margin: 0;
            display: flex;
        }

        /* Main content area */
        .main-content {
            flex-grow: 1;
            padding: 40px;
            overflow-y: auto;
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        .header h1 {
            color: #2d3748;
            font-size: 2rem;
            font-weight: bold;
            margin: 0;
        }
        .header h1 i {
            margin-right: 10px;
            color: #4c51bf;
        }
        .back-btn {
            background-color: #edf2f7;
            color: #4a5568;
            border: 1px solid #e2e8f0;
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .back-btn:hover {
            background-color: #4c51bf;
            color: white;
            border-color: #4c51bf;
        }

        /* Form Container */
        .form-container {
            background-color: white;
            border-radius: 8px;
            padding: 30px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            max-width: 800px;
            margin: 0 auto;
        }

        /* Form Sections */
        .form-section {
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid #e2e8f0;
        }
        .form-section:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }
        .section-title {
            color: #2d3748;
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .section-title i {
            color: #4c51bf;
            font-size: 1.3rem;
        }

        /* Form Grid */
        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group.full-width {
            grid-column: span 2;
        }
        .form-label {
            display: block;
            margin-bottom: 8px;
            color: #4a5568;
            font-weight: 500;
            font-size: 0.95rem;
        }
        .form-label i {
            color: #4c51bf;
            margin-right: 6px;
            font-size: 0.9rem;
        }
        .form-control {
            width: 100%;
            padding: 12px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            font-size: 1rem;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }
        .form-control:focus {
            outline: none;
            border-color: #4c51bf;
            box-shadow: 0 0 0 3px rgba(76, 81, 191, 0.2);
        }
        .form-control[readonly] {
            background-color: #f7fafc;
            cursor: not-allowed;
        }
        textarea.form-control {
            resize: vertical;
            min-height: 100px;
        }

        /* Coupon Code Display */
        .coupon-code-display {
            background-color: #ebf4ff;
            border: 2px dashed #4c51bf;
            border-radius: 6px;
            padding: 15px;
            text-align: center;
            margin-bottom: 20px;
        }
        .coupon-code-display .code {
            font-size: 1.8rem;
            font-weight: bold;
            color: #4c51bf;
            letter-spacing: 2px;
        }
        .coupon-code-display .note {
            color: #718096;
            font-size: 0.9rem;
            margin-top: 5px;
        }
        .coupon-code-display .note i {
            color: #4c51bf;
            margin-right: 5px;
        }

        /* Usage Stats */
        .usage-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-bottom: 20px;
            background-color: #f7fafc;
            padding: 15px;
            border-radius: 8px;
        }
        .stat-item {
            text-align: center;
        }
        .stat-label {
            color: #718096;
            font-size: 0.85rem;
            margin-bottom: 5px;
        }
        .stat-value {
            color: #2d3748;
            font-size: 1.5rem;
            font-weight: bold;
        }
        .stat-value i {
            color: #4c51bf;
            font-size: 1.2rem;
            margin-right: 5px;
        }

        /* Discount Type Toggle */
        .discount-type {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
        }
        .discount-option {
            flex: 1;
            position: relative;
        }
        .discount-option input[type="radio"] {
            display: none;
        }
        .discount-option label {
            display: block;
            padding: 12px;
            text-align: center;
            background-color: #edf2f7;
            border: 2px solid #e2e8f0;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 500;
        }
        .discount-option input[type="radio"]:checked + label {
            background-color: #4c51bf;
            border-color: #4c51bf;
            color: white;
        }
        .discount-option label i {
            margin-right: 8px;
        }

        /* Input with icon */
        .input-with-icon {
            position: relative;
        }
        .input-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #a0aec0;
        }
        .input-with-icon .form-control {
            padding-left: 35px;
        }

        /* Toggle Switch */
        .toggle-switch {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-top: 10px;
        }
        .switch {
            position: relative;
            display: inline-block;
            width: 60px;
            height: 34px;
        }
        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #cbd5e0;
            transition: .3s;
            border-radius: 34px;
        }
        .slider:before {
            position: absolute;
            content: "";
            height: 26px;
            width: 26px;
            left: 4px;
            bottom: 4px;
            background-color: white;
            transition: .3s;
            border-radius: 50%;
        }
        input:checked + .slider {
            background-color: #4c51bf;
        }
        input:checked + .slider:before {
            transform: translateX(26px);
        }
        .toggle-label {
            color: #4a5568;
            font-weight: 500;
        }
        .toggle-label i {
            color: #4c51bf;
            margin-right: 5px;
        }

        /* Form Actions */
        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
        }
        .btn {
            padding: 12px 30px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .btn-primary {
            background-color: #4c51bf;
            color: white;
        }
        .btn-primary:hover {
            background-color: #3b3f8f;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(76, 81, 191, 0.3);
        }
        .btn-secondary {
            background-color: #edf2f7;
            color: #4a5568;
            border: 1px solid #e2e8f0;
        }
        .btn-secondary:hover {
            background-color: #e2e8f0;
            transform: translateY(-2px);
        }
        .btn-danger {
            background-color: #e53e3e;
            color: white;
        }
        .btn-danger:hover {
            background-color: #c53030;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(229, 62, 62, 0.3);
        }

        /* Message area styling */
        .message-area {
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 8px;
            text-align: center;
            font-weight: bold;
            display: none;
        }
        .error-message {
            background-color: #fed7d7;
            color: #c53030;
            display: block;
        }
        .success-message {
            background-color: #c6f6d5;
            color: #2f855a;
            display: block;
        }
        .info-message {
            background-color: #bee3f8;
            color: #2c5282;
            display: block;
        }

        /* Loading indicator */
        .loading {
            display: none;
            text-align: center;
            padding: 20px;
            color: #4c51bf;
        }
        .loading-spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #4c51bf;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
            margin: 0 auto;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Helper text */
        .helper-text {
            color: #718096;
            font-size: 0.85rem;
            margin-top: 5px;
        }
        .helper-text i {
            color: #4c51bf;
            margin-right: 5px;
            font-size: 0.8rem;
        }

        /* Warning box */
        .warning-box {
            background-color: #fff3cd;
            border: 1px solid #ffeeba;
            color: #856404;
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .warning-box i {
            font-size: 1.5rem;
            color: #856404;
        }
        .warning-box p {
            margin: 0;
            font-size: 0.95rem;
        }

        /* ----- Responsive adjustments (no HTML changes) ----- */
        @media screen and (max-width: 768px) {
            body {
                flex-direction: column;
            }

            .main-content {
                padding: 20px 16px;
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
                margin-bottom: 20px;
            }

            .header h1 {
                font-size: 1.8rem;
            }

            .back-btn {
                width: 100%;
                justify-content: center;
            }

            .form-container {
                padding: 20px;
                max-width: 100%;
            }

            .form-grid {
                grid-template-columns: 1fr;
                gap: 0;
            }

            .form-group.full-width {
                grid-column: span 1;
            }

            .discount-type {
                flex-direction: column;
                gap: 10px;
            }

            .form-actions {
                flex-direction: column;
                gap: 10px;
            }

            .btn {
                width: 100%;
                justify-content: center;
                padding: 12px 20px;
            }

            .usage-stats {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .coupon-code-display .code {
                font-size: 1.5rem;
            }

            .section-title {
                font-size: 1.1rem;
            }

            .toggle-switch {
                flex-wrap: wrap;
            }

            .warning-box {
                flex-direction: column;
                text-align: center;
            }

            /* Modal responsive */
            .confirmation-modal {
                padding: 0 10px;
            }

            .confirmation-content {
                width: 95%;
                padding: 20px;
                margin: 10px;
            }

            .confirmation-buttons {
                flex-direction: column;
                gap: 10px;
            }

            .confirmation-btn {
                width: 100%;
            }
        }

        @media screen and (max-width: 480px) {
            .main-content {
                padding: 15px 12px;
            }

            .header h1 {
                font-size: 1.5rem;
            }

            .form-container {
                padding: 16px;
            }

            .form-control {
                padding: 10px;
                font-size: 0.95rem;
            }

            .btn {
                padding: 10px 16px;
                font-size: 0.95rem;
            }

            .coupon-code-display .code {
                font-size: 1.3rem;
            }

            .stat-value {
                font-size: 1.3rem;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <%- include("../partials/admin/navigation.ejs") %>
    
    <!-- Main Content -->
    <div class="main-content">
        <!-- Header -->
        <div class="header">
            <h1>
                <i class="fas fa-edit"></i>
                Edit Coupon
            </h1>
            <a href="/admin/coupon" class="back-btn">
                <i class="fas fa-arrow-left"></i>
                Back to Coupons
            </a>
        </div>

        <!-- Message Area -->
        <div class="message-area" id="message-area"></div>

        <!-- Form Container -->
        <div class="form-container">
            <!-- Warning Box for Inactive Coupons -->
            <% if (coupon && coupon.status === 'inactive') { %>
            <div class="warning-box">
                <i class="fas fa-exclamation-triangle"></i>
                <p>This coupon is currently inactive and won't be visible to customers. You can activate it by toggling the status switch below.</p>
            </div>
            <% } %>

            <form id="editCouponForm" method="POST" action="/admin/updatecoupon/<%= coupon._id %>">
                <!-- Coupon Code Display (Read-only) -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fas fa-tag"></i>
                        Coupon Information
                    </div>

                    <div class="coupon-code-display">
                        <div class="code">
                            <i class="fas fa-ticket-alt"></i>
                            <%= coupon.couponCode %>
                        </div>
                        <div class="note">
                            <i class="fas fa-info-circle"></i>
                            Coupon code cannot be changed after creation
                        </div>
                    </div>

                    <!-- Usage Statistics -->
                    <div class="usage-stats">
                        <div class="stat-item">
                            <div class="stat-label">Times Used</div>
                            <div class="stat-value">
                                <i class="fas fa-users"></i>
                                <%= coupon.usedCount || 0 %>
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-label">Created On</div>
                            <div class="stat-value">
                                <i class="fas fa-calendar"></i>
                                <%= new Date(coupon.expiryDate).toLocaleDateString('en-IN') %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Basic Information Section -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fas fa-info-circle"></i>
                        Basic Information
                    </div>
                    
                    <div class="form-grid">
                        <div class="form-group full-width">
                            <label class="form-label">
                                <i class="fas fa-align-left"></i>
                                Description
                            </label>
                            <textarea class="form-control" 
                                      name="description" 
                                      placeholder="Enter coupon description..." 
                                      required><%= coupon.description %></textarea>
                            <div class="helper-text">
                                <i class="fas fa-info-circle"></i>
                                Describe what this coupon offers to customers
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Discount Details Section -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fas fa-percent"></i>
                        Discount Details
                    </div>

                    <div class="discount-type">
                        <div class="discount-option">
                            <input type="radio" name="discountType" id="percentage" value="percentage" <%= coupon.discountType === 'percentage' ? 'checked' : '' %>>
                            <label for="percentage">
                                <i class="fas fa-percent"></i>
                                Percentage Discount
                            </label>
                        </div>
                        <div class="discount-option">
                            <input type="radio" name="discountType" id="fixed" value="fixed" <%= coupon.discountType === 'fixed' ? 'checked' : '' %>>
                            <label for="fixed">
                                <i class="fas fa-rupee-sign"></i>
                                Fixed Amount
                            </label>
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label" id="discountValueLabel">
                                <i class="fas <%= coupon.discountType === 'percentage' ? 'fa-percent' : 'fa-rupee-sign' %>"></i>
                                Discount Value <%= coupon.discountType === 'percentage' ? '(%)' : '(₹)' %>
                            </label>
                            <div class="input-with-icon">
                                <i class="fas <%= coupon.discountType === 'percentage' ? 'fa-percent' : 'fa-rupee-sign' %> input-icon" id="discountIcon"></i>
                                <input type="number" 
                                       class="form-control" 
                                       name="discountValue" 
                                       id="discountValue"
                                       min="1" 
                                       <%= coupon.discountType === 'percentage' ? 'max="100"' : '' %>
                                       step="0.01"
                                       placeholder="Enter discount value" 
                                       value="<%= coupon.discountValue %>"
                                       required>
                            </div>
                            <div class="helper-text" id="discountHelper">
                                <i class="fas fa-info-circle"></i>
                                <%= coupon.discountType === 'percentage' ? 'Enter value between 1 and 100' : 'Enter the discount amount in rupees' %>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-shopping-cart"></i>
                                Minimum Purchase (₹)
                            </label>
                            <div class="input-with-icon">
                                <i class="fas fa-rupee-sign input-icon"></i>
                                <input type="number" 
                                       class="form-control" 
                                       name="minPurchaseAmount" 
                                       min="0" 
                                       step="0.01"
                                       placeholder="0 = No minimum"
                                       value="<%= coupon.minPurchaseAmount %>">
                            </div>
                            <div class="helper-text">
                                <i class="fas fa-info-circle"></i>
                                Leave 0 for no minimum purchase
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Usage Limits Section -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fas fa-chart-line"></i>
                        Usage Limits
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-redo-alt"></i>
                                Max Redemptions
                            </label>
                            <input type="number" 
                                   class="form-control" 
                                   name="maxRedemption" 
                                   min="0" 
                                   step="1"
                                   placeholder="0 = Unlimited"
                                   value="<%= coupon.maxRedemption %>">
                            <div class="helper-text">
                                <i class="fas fa-info-circle"></i>
                                Maximum number of times this coupon can be used
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-calendar-alt"></i>
                                Expiry Date
                            </label>
                            <input type="date" 
                                   class="form-control" 
                                   name="expiryDate" 
                                   required
                                   min="<%= new Date().toISOString().split('T')[0] %>"
                                   value="<%= new Date(coupon.expiryDate).toISOString().split('T')[0] %>">
                            <div class="helper-text">
                                <i class="fas fa-info-circle"></i>
                                Coupon will expire at the end of this day
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Status Section -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fas fa-toggle-on"></i>
                        Status
                    </div>

                    <div class="toggle-switch">
                        <label class="switch">
                            <input type="checkbox" name="status" value="active" <%= coupon.status === 'active' ? 'checked' : '' %>>
                            <span class="slider"></span>
                        </label>
                        <span class="toggle-label">
                            <i class="fas fa-check-circle"></i>
                            Active (Coupon is available to customers)
                        </span>
                    </div>
                    <div class="helper-text" style="margin-top: 10px;">
                        <i class="fas fa-info-circle"></i>
                        Inactive coupons won't be visible to customers
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <a href="/admin/coupon" class="btn btn-secondary">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                    <button type="button" class="btn btn-danger" id="resetBtn">
                        <i class="fas fa-undo"></i>
                        Reset Changes
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i>
                        Update Coupon
                    </button>
                </div>
            </form>
        </div>

        <!-- Loading Indicator -->
        <div class="loading" id="loading-indicator">
            <div class="loading-spinner"></div>
            <p>Updating coupon...</p>
        </div>
    </div>

    <!-- Confirmation Modal -->
    <div id="confirmationModal" class="confirmation-modal" style="display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.6); justify-content: center; align-items: center;">
        <div class="confirmation-content" style="background-color: #fff; padding: 30px; border-radius: 10px; width: 90%; max-width: 450px; box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3); text-align: center;">
            <h3 style="margin-top: 0; margin-bottom: 15px; color: #2d3748;" id="confirmation-title">Confirm Changes</h3>
            <p style="margin-bottom: 25px; color: #4a5568;" id="confirmation-message">Are you sure you want to update this coupon?</p>
            <div class="confirmation-buttons" style="display: flex; justify-content: center; gap: 15px;">
                <button class="confirmation-btn cancel" onclick="closeConfirmationModal()" style="padding: 10px 20px; border: none; border-radius: 6px; cursor: pointer; font-size: 1rem; background-color: #e2e8f0; color: #4a5568;">Cancel</button>
                <button class="confirmation-btn confirm" id="confirmation-confirm-btn" style="padding: 10px 20px; border: none; border-radius: 6px; cursor: pointer; font-size: 1rem; background-color: #4c51bf; color: white;">Confirm</button>
            </div>
        </div>
    </div>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('editCouponForm');
            const messageArea = document.getElementById('message-area');
            const loadingIndicator = document.getElementById('loading-indicator');
            const resetBtn = document.getElementById('resetBtn');
            const confirmationModal = document.getElementById('confirmationModal');
            const confirmationTitle = document.getElementById('confirmation-title');
            const confirmationMessage = document.getElementById('confirmation-message');
            const confirmationConfirmBtn = document.getElementById('confirmation-confirm-btn');
            
            // Original form data for reset - Fixed formatting
            const originalData = {
                description: `<%= coupon.description %>`,
                discountType: '<%= coupon.discountType %>',
                discountValue: '<%= coupon.discountValue %>',
                minPurchaseAmount: '<%= coupon.minPurchaseAmount %>',
                maxRedemption: '<%= coupon.maxRedemption %>',
                expiryDate: '<%= new Date(coupon.expiryDate).toISOString().split("T")[0] %>',
                status: '<%= coupon.status === "active" ? "true" : "false" %>'
            };

            // Discount type toggle elements
            const percentageRadio = document.getElementById('percentage');
            const fixedRadio = document.getElementById('fixed');
            const discountValueLabel = document.getElementById('discountValueLabel');
            const discountIcon = document.getElementById('discountIcon');
            const discountHelper = document.getElementById('discountHelper');
            const discountValue = document.getElementById('discountValue');
            const statusCheckbox = document.querySelector('input[name="status"]');

            // Set minimum date for expiry date input
            const expiryDateInput = document.querySelector('input[name="expiryDate"]');
            const today = new Date().toISOString().split('T')[0];
            expiryDateInput.setAttribute('min', today);

            // Handle discount type change
            function updateDiscountFields() {
                if (percentageRadio.checked) {
                    // Percentage mode
                    discountValueLabel.innerHTML = '<i class="fas fa-percent"></i> Discount Value (%)';
                    discountIcon.className = 'fas fa-percent input-icon';
                    discountValue.max = 100;
                    discountValue.min = 1;
                    discountValue.step = 0.01;
                    discountValue.placeholder = 'Enter percentage';
                    discountHelper.innerHTML = '<i class="fas fa-info-circle"></i> Enter value between 1 and 100';
                } else {
                    // Fixed amount mode
                    discountValueLabel.innerHTML = '<i class="fas fa-rupee-sign"></i> Discount Amount (₹)';
                    discountIcon.className = 'fas fa-rupee-sign input-icon';
                    discountValue.removeAttribute('max');
                    discountValue.min = 1;
                    discountValue.step = 0.01;
                    discountValue.placeholder = 'Enter amount';
                    discountHelper.innerHTML = '<i class="fas fa-info-circle"></i> Enter the discount amount in rupees';
                }
            }

            percentageRadio.addEventListener('change', updateDiscountFields);
            fixedRadio.addEventListener('change', updateDiscountFields);

            // Form validation and submission
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Check if any changes were made
                if (!hasChanges()) {
                    showMessage('No changes were made to the coupon', 'info');
                    return;
                }

                // Get form values
                const description = document.querySelector('textarea[name="description"]').value.trim();
                const discountValue = parseFloat(document.querySelector('input[name="discountValue"]').value);
                const minPurchase = parseFloat(document.querySelector('input[name="minPurchaseAmount"]').value);
                const maxRedemption = parseInt(document.querySelector('input[name="maxRedemption"]').value);
                const expiryDate = document.querySelector('input[name="expiryDate"]').value;

                // Validate description
                if (!description) {
                    showMessage('Please enter a description', 'error');
                    return;
                }
                if (description.length < 10) {
                    showMessage('Description must be at least 10 characters long', 'error');
                    return;
                }

                // Validate discount value
                if (!discountValue || discountValue <= 0) {
                    showMessage('Please enter a valid discount value', 'error');
                    return;
                }

                if (percentageRadio.checked) {
                    if (discountValue > 100) {
                        showMessage('Percentage discount cannot exceed 100%', 'error');
                        return;
                    }
                }

                // Validate min purchase
                if (minPurchase < 0) {
                    showMessage('Minimum purchase amount cannot be negative', 'error');
                    return;
                }

                // Validate max redemption
                if (maxRedemption < 0) {
                    showMessage('Max redemptions cannot be negative', 'error');
                    return;
                }

                // Validate expiry date
                if (!expiryDate) {
                    showMessage('Please select an expiry date', 'error');
                    return;
                }

                const selectedDate = new Date(expiryDate);
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                
                if (selectedDate < today) {
                    showMessage('Expiry date cannot be in the past', 'error');
                    return;
                }

                // Show confirmation modal
                openConfirmationModal(
                    'Update Coupon',
                    'Are you sure you want to update this coupon?',
                    function() {
                        showLoading();
                        form.submit();
                    }
                );
            });

            // Check if any changes were made
            function hasChanges() {
                const currentDescription = document.querySelector('textarea[name="description"]').value.trim();
                const currentDiscountType = percentageRadio.checked ? 'percentage' : 'fixed';
                const currentDiscountValue = document.querySelector('input[name="discountValue"]').value;
                const currentMinPurchase = document.querySelector('input[name="minPurchaseAmount"]').value;
                const currentMaxRedemption = document.querySelector('input[name="maxRedemption"]').value;
                const currentExpiryDate = document.querySelector('input[name="expiryDate"]').value;
                const currentStatus = statusCheckbox.checked;

                return currentDescription !== originalData.description ||
                       currentDiscountType !== originalData.discountType ||
                       currentDiscountValue !== originalData.discountValue ||
                       currentMinPurchase !== originalData.minPurchaseAmount ||
                       currentMaxRedemption !== originalData.maxRedemption ||
                       currentExpiryDate !== originalData.expiryDate ||
                       currentStatus !== originalData.status;
            }

            // Reset button handler
            resetBtn.addEventListener('click', function() {
                openConfirmationModal(
                    'Reset Changes',
                    'Are you sure you want to reset all changes? This will revert to the original values.',
                    function() {
                        // Reset form to original values
                        document.querySelector('textarea[name="description"]').value = originalData.description;
                        
                        if (originalData.discountType === 'percentage') {
                            percentageRadio.checked = true;
                        } else {
                            fixedRadio.checked = true;
                        }
                        updateDiscountFields();
                        
                        document.querySelector('input[name="discountValue"]').value = originalData.discountValue;
                        document.querySelector('input[name="minPurchaseAmount"]').value = originalData.minPurchaseAmount;
                        document.querySelector('input[name="maxRedemption"]').value = originalData.maxRedemption;
                        document.querySelector('input[name="expiryDate"]').value = originalData.expiryDate;
                        statusCheckbox.checked = originalData.status;
                        
                        showMessage('Form has been reset to original values', 'success');
                    }
                );
            });

            // Modal functions
            function openConfirmationModal(title, message, confirmCallback) {
                confirmationTitle.textContent = title;
                confirmationMessage.textContent = message;
                confirmationConfirmBtn.onclick = function() {
                    confirmCallback();
                    closeConfirmationModal();
                };
                confirmationModal.style.display = 'flex';
            }

            window.closeConfirmationModal = function() {
                confirmationModal.style.display = 'none';
            };

            // Close modal when clicking outside
            window.addEventListener('click', (e) => {
                if (e.target === confirmationModal) {
                    closeConfirmationModal();
                }
            });

            // Function to show loading
            function showLoading() {
                loadingIndicator.style.display = 'block';
            }

            // Function to show messages
            function showMessage(message, type) {
                messageArea.textContent = message;
                messageArea.className = 'message-area ' + (type === 'success' ? 'success-message' : type === 'info' ? 'info-message' : 'error-message');
                messageArea.style.display = 'block';
                
                // Auto hide after 5 seconds
                setTimeout(() => {
                    messageArea.style.display = 'none';
                }, 5000);
            }

            // Check for URL parameters to show messages
            const urlParams = new URLSearchParams(window.location.search);
            const error = urlParams.get('error');
            const success = urlParams.get('success');
            
            if (error) {
                showMessage(decodeURIComponent(error), 'error');
            } else if (success) {
                showMessage(decodeURIComponent(success), 'success');
            }

            // Prevent form resubmission on page refresh
            if (window.history.replaceState) {
                window.history.replaceState(null, null, window.location.pathname);
            }
        });
    </script>
</body>
</html>