<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification</title>
    <style> 
body {
    font-family: Arial, sans-serif;
    background-color: #f9f9fb;
    margin: 0;
    padding: 0;
}

header {
    padding: 1rem;
    border-bottom: 1px solid #eee;
}

.brand {
    font-size: 1.2rem;
    font-weight: bold;
    margin: 0;
}

main {
    display: flex;
    justify-content: center;
    align-items: center;
    height: calc(100vh - 60px);
}

.otp-container {
    text-align: center;
}

.otp-container h2 {
    font-weight: bold;
    margin-bottom: 0.5rem;
}

.otp-container p {
    color: #555;
    margin-bottom: 1.5rem;
}

.otp-inputs {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
}

.otp-inputs input {
    width: 45px;
    height: 45px;
    text-align: center;
    font-size: 1.5rem;
    border: 1px solid #ccc;
    border-radius: 4px;
}

.verify-btn {
    display: inline-block;
    background-color: #5663f7;
    color: white;
    border: none;
    padding: 0.5rem 1.5rem;
    border-radius: 20px;
    font-size: 1rem;
    cursor: pointer;
    margin-bottom: 0.5rem;
}

.verify-btn:hover {
    background-color: #4350d8;
}

.resend-link {
    display: block;
    font-size: 0.9rem;
    color: #5663f7;
    text-decoration: none;
}

.resend-link:hover {
    text-decoration: underline;
}
    </style>
</head>
<body>
    <header>
        <h1 class="brand">Artemis</h1>
    </header>

    <main>
        <div class="otp-container">
            <h2>OTP Verification</h2>
            <p>Please enter the One-Time Password (OTP) sent to your registered phone number or email address.</p>
            
            <form action="/verify-otp" method="POST" class="otp-form">
                <div class="otp-inputs">
                    <input type="text" maxlength="1" name="otp1" required>
                    <input type="text" maxlength="1" name="otp2" required>
                    <input type="text" maxlength="1" name="otp3" required>
                    <input type="text" maxlength="1" name="otp4" required>
                    <input type="text" maxlength="1" name="otp5" required>
                    <input type="text" maxlength="1" name="otp6" required>
                </div>

                <button type="submit" class="verify-btn">Verify</button>
                <a href="#" class="resend-link">Resend OTP (<%= timer || '00:30' %>)</a>
            </form>
        </div>
    </main>
</body>
</html>
