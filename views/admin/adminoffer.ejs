<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Offer Management - Admin</title>
    <style>
        /* General body and layout styling */
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7f9;
            margin: 0;
            display: flex;
        }

        /* Main content area */
        .main-content {
            flex-grow: 1;
            padding: 40px;
            overflow-y: auto;
        }

        /* Header and buttons */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        .header h1 {
            color: #2d3748;
            font-size: 2rem;
            font-weight: bold;
            margin: 0;
        }
        .header h1 i {
            margin-right: 10px;
            color: #4c51bf;
        }
        .add-offer-btn {
            background-color: #4c51bf;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1rem;
            transition: background-color 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .add-offer-btn:hover {
            background-color: #3b3f8f;
        }

        /* Search box styling */
        .search-container {
            display: flex;
            margin-bottom: 20px;
            max-width: 400px;
            position: relative;
        }
        .search-input {
            flex-grow: 1;
            padding: 12px 45px 12px 15px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.3s ease;
        }
        .search-input:focus {
            border-color: #4c51bf;
            box-shadow: 0 0 0 3px rgba(76, 81, 191, 0.2);
        }
        .search-clear {
            position: absolute;
            right: 40px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #a0aec0;
            cursor: pointer;
            font-size: 18px;
            display: none;
        }
        .search-clear:hover {
            color: #4a5568;
        }
        .search-btn {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #4c51bf;
            cursor: pointer;
            font-size: 18px;
        }

        /* Table styling */
        .offer-table {
            width: 100%;
            border-collapse: collapse;
            background-color: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .offer-table th, .offer-table td {
            text-align: left;
            padding: 15px;
            border-bottom: 1px solid #e2e8f0;
        }
        .offer-table th {
            background-color: #f7fafc;
            color: #4a5568;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 0.8rem;
        }
        .offer-table tr:hover {
            background-color: #edf2f7;
        }

        /* Offer name styling */
        .offer-name {
            font-weight: bold;
            color: #4c51bf;
            background-color: #ebf4ff;
            padding: 4px 8px;
            border-radius: 4px;
            display: inline-block;
        }

        /* Discount badge */
        .discount-badge {
            background-color: #2f855a;
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            font-weight: 500;
            font-size: 0.9rem;
            display: inline-block;
        }

        /* Type badge */
        .type-badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: 500;
            display: inline-block;
        }
        .type-product {
            background-color: #805ad5;
            color: white;
        }
        .type-category {
            background-color: #dd6b20;
            color: white;
        }

        /* Status badges */
        .status-badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
            display: inline-block;
        }
        .status-active {
            background-color: #c6f6d5;
            color: #2f855a;
        }
        .status-inactive {
            background-color: #fed7d7;
            color: #c53030;
        }
        .status-expired {
            background-color: #e2e8f0;
            color: #4a5568;
        }

        /* Date range styling */
        .date-range {
            font-size: 0.9rem;
        }
        .date-range i {
            color: #4c51bf;
            margin-right: 4px;
            font-size: 0.8rem;
        }
        .date-range .expired {
            color: #e53e3e;
        }
        .date-range .active {
            color: #2f855a;
        }

        /* Actions links */
        .actions {
            display: flex;
            gap: 10px;
        }
        .actions a, .actions button {
            color: #4c51bf;
            text-decoration: none;
            padding: 6px 12px;
            border-radius: 4px;
            transition: all 0.3s ease;
            font-size: 0.9rem;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        .actions a:hover {
            background-color: #ebf4ff;
        }
        .actions .edit-btn {
            background-color: #ebf4ff;
            color: #4c51bf;
        }
        .actions .status-btn {
            background-color: #fed7d7;
            color: #c53030;
        }
        .actions .status-btn.active {
            background-color: #c6f6d5;
            color: #2f855a;
        }
        .actions .status-btn:hover {
            opacity: 0.8;
        }

        /* Message area styling */
        .message-area {
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 8px;
            text-align: center;
            font-weight: bold;
            display: none;
        }
        .error-message {
            background-color: #fed7d7;
            color: #c53030;
            display: block;
        }
        .success-message {
            background-color: #c6f6d5;
            color: #2f855a;
            display: block;
        }
        .info-message {
            background-color: #bee3f8;
            color: #2c5282;
            display: block;
        }

        /* Pagination Styles */
        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 30px;
            gap: 8px;
        }

        .pagination-btn, .pagination-page {
            padding: 8px 16px;
            text-decoration: none;
            border-radius: 6px;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .pagination-btn {
            background-color: #edf2f7;
            color: #4a5568;
            border: 1px solid #e2e8f0;
        }

        .pagination-btn:hover:not(.disabled) {
            background-color: #4c51bf;
            color: white;
            border-color: #4c51bf;
        }

        .pagination-page {
            border: 1px solid #e2e8f0;
            color: #4a5568;
            background-color: white;
        }

        .pagination-page.active {
            background-color: #4c51bf;
            color: white;
            border-color: #4c51bf;
        }

        .pagination-page:hover:not(.active) {
            background-color: #edf2f7;
        }

        .pagination-btn.disabled, .pagination-page.disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .pagination-ellipsis {
            padding: 8px 4px;
            color: #a0aec0;
        }

        /* Loading indicator */
        .loading {
            display: none;
            text-align: center;
            padding: 20px;
            color: #4c51bf;
        }
        .loading-spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #4c51bf;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
            margin: 0 auto;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Confirmation Modal */
        .confirmation-modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.6);
            justify-content: center;
            align-items: center;
        }
        .confirmation-content {
            background-color: #fff;
            padding: 30px;
            border-radius: 10px;
            width: 90%;
            max-width: 450px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
            text-align: center;
        }
        .confirmation-content h3 {
            margin-top: 0;
            margin-bottom: 15px;
            color: #2d3748;
        }
        .confirmation-content p {
            margin-bottom: 25px;
            color: #4a5568;
        }
        .confirmation-buttons {
            display: flex;
            justify-content: center;
            gap: 15px;
        }
        .confirmation-btn {
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1rem;
            transition: background-color 0.3s ease;
        }
        .confirmation-btn.confirm {
            background-color: #4c51bf;
            color: white;
        }
        .confirmation-btn.confirm:hover {
            background-color: #3b3f8f;
        }
        .confirmation-btn.cancel {
            background-color: #e2e8f0;
            color: #4a5568;
        }
        .confirmation-btn.cancel:hover {
            background-color: #cbd5e0;
        }

        /* No data styling */
        .no-data {
            text-align: center;
            padding: 50px;
            color: #718096;
        }
        .no-data i {
            font-size: 60px;
            color: #cbd5e0;
            margin-bottom: 20px;
        }
        .no-data h4 {
            color: #4a5568;
            margin-bottom: 10px;
        }

        /* Responsive design */
        @media (max-width: 768px) {
            .main-content {
                padding: 20px;
            }
            
            .header {
                flex-direction: column;
                gap: 15px;
                align-items: flex-start;
            }
            
            .search-container {
                max-width: 100%;
            }
            
            .offer-table {
                display: block;
                overflow-x: auto;
            }
            
            .actions {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <%- include("../partials/admin/navigation.ejs") %>
    
    <!-- Main Content -->
    <div class="main-content">
        <!-- Header -->
        <div class="header">
            <h1>
                <i class="fas fa-gift"></i>
                Offer Management
            </h1>
            <!-- FIXED: Added URL encoding for the space in "add Offer" -->
            <a href="/admin/addOffer" class="add-offer-btn">
                <i class="fas fa-plus"></i>
                Add New Offer
            </a>
        </div>

        <!-- Message Area -->
        <div class="message-area" id="message-area"></div>

        <!-- Search Box -->
        <div class="search-container">
            <input type="text" id="search-input" class="search-input" placeholder="Search offers by name..." value="<%= searchQuery || '' %>">
            <button id="search-clear" class="search-clear">&times;</button>
            <button id="search-btn" class="search-btn">
                <i class="fas fa-search"></i>
            </button>
        </div>

        <!-- Loading Indicator -->
        <div class="loading" id="loading-indicator">
            <div class="loading-spinner"></div>
            <p>Searching offers...</p>
        </div>

        <!-- Offer Table -->
        <% if (offers && offers.length > 0) { %>
        <table class="offer-table">
            <thead>
                <tr>
                    <th>Offer Name</th>
                    <th>Type</th>
                    <th>Discount</th>
                    <th>Target</th>
                    <th>Valid Period</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="offer-table-body">
                <% offers.forEach(offer => { 
                    const today = new Date();
                    const start = new Date(offer.startDate);
                    const end = new Date(offer.endDate);
                    const isExpired = end < today;
                    const isUpcoming = start > today;
                    
                    let status = offer.status ? 'active' : 'inactive';
                    if (isExpired) status = 'expired';
                    
                    const statusClass = status === 'active' ? 'status-active' : 
                                       status === 'inactive' ? 'status-inactive' : 'status-expired';
                    
                    const statusText = status === 'active' ? 'Active' : 
                                      status === 'inactive' ? 'Inactive' : 'Expired';
                %>
                <tr>
                    <td>
                        <span class="offer-name">
                            <i class="fas fa-gift" style="margin-right: 5px;"></i>
                            <%= offer.offerName %>
                        </span>
                    </td>
                    <td>
                        <span class="type-badge <%= offer.offerType === 'product' ? 'type-product' : 'type-category' %>">
                            <i class="fas <%= offer.offerType === 'product' ? 'fa-box' : 'fa-tags' %>"></i>
                            <%= offer.offerType === 'product' ? 'Product' : 'Category' %>
                        </span>
                    </td>
                    <td>
                        <span class="discount-badge">
                            <i class="fas fa-percent"></i>
                            <%= offer.discount %>%
                        </span>
                    </td>
                    <td>
                        <% if (offer.offerType === 'product') { %>
                            <span class="target-info">
                                <i class="fas fa-box"></i>
                                Product ID: <%= offer.productId %>
                            </span>
                        <% } else { %>
                            <span class="target-info">
                                <i class="fas fa-tags"></i>
                                Category ID: <%= offer.categoryId %>
                            </span>
                        <% } %>
                    </td>
                    <td>
                        <div class="date-range">
                            <div class="<%= isUpcoming ? '' : (isExpired ? 'expired' : 'active') %>">
                                <i class="fas fa-calendar-alt"></i>
                                <%= new Date(offer.startDate).toLocaleDateString('en-IN') %>
                                -
                                <%= new Date(offer.endDate).toLocaleDateString('en-IN') %>
                            </div>
                            <% if (isUpcoming) { %>
                                <small style="color: #805ad5;">
                                    <i class="fas fa-clock"></i> Upcoming
                                </small>
                            <% } else if (isExpired) { %>
                                <small style="color: #e53e3e;">
                                    <i class="fas fa-hourglass-end"></i> Expired
                                </small>
                            <% } else { %>
                                <small style="color: #2f855a;">
                                    <i class="fas fa-hourglass-half"></i> Active
                                </small>
                            <% } %>
                        </div>
                    </td>
                    <td>
                        <span class="status-badge <%= statusClass %>">
                            <%= statusText %>
                        </span>
                    </td>
                    <td class="actions">
                        <a href="/admin/editoffer/<%= offer._id %>" class="edit-btn">
                            <i class="fas fa-edit"></i>
                            Edit
                        </a>
                        <% if (!isExpired) { %>
                        <button class="status-btn <%= status === 'active' ? 'active' : '' %>" 
                                data-id="<%= offer._id %>" 
                                data-status="<%= offer.status %>">
                            <i class="fas <%= status === 'active' ? 'fa-ban' : 'fa-check-circle' %>"></i>
                            <%= status === 'active' ? 'Block' : 'Activate' %>
                        </button>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <!-- Pagination -->
        <% if (pagination && pagination.totalPages > 1) { %>
        <div class="pagination" id="pagination-container">
            <!-- Previous Button -->
            <% if (pagination.currentPage > 1) { %>
                <a href="?page=<%= pagination.currentPage - 1 %><%= searchQuery ? '&query=' + encodeURIComponent(searchQuery) : '' %>" class="pagination-btn">
                    <i class="fas fa-chevron-left"></i> Previous
                </a>
            <% } else { %>
                <span class="pagination-btn disabled">
                    <i class="fas fa-chevron-left"></i> Previous
                </span>
            <% } %>
            
            <!-- Page Numbers -->
            <% 
            let startPage = Math.max(1, pagination.currentPage - 2);
            let endPage = Math.min(pagination.totalPages, startPage + 4);
            
            if (endPage - startPage < 4) {
                startPage = Math.max(1, endPage - 4);
            }
            %>
            
            <% if (startPage > 1) { %>
                <a href="?page=1<%= searchQuery ? '&query=' + encodeURIComponent(searchQuery) : '' %>" class="pagination-page">1</a>
                <% if (startPage > 2) { %>
                    <span class="pagination-ellipsis">...</span>
                <% } %>
            <% } %>
            
            <% for(let i = startPage; i <= endPage; i++) { %>
                <% if (i === pagination.currentPage) { %>
                    <span class="pagination-page active"><%= i %></span>
                <% } else { %>
                    <a href="?page=<%= i %><%= searchQuery ? '&query=' + encodeURIComponent(searchQuery) : '' %>" class="pagination-page"><%= i %></a>
                <% } %>
            <% } %>
            
            <% if (endPage < pagination.totalPages) { %>
                <% if (endPage < pagination.totalPages - 1) { %>
                    <span class="pagination-ellipsis">...</span>
                <% } %>
                <a href="?page=<%= pagination.totalPages %><%= searchQuery ? '&query=' + encodeURIComponent(searchQuery) : '' %>" class="pagination-page"><%= pagination.totalPages %></a>
            <% } %>
            
            <!-- Next Button -->
            <% if (pagination.currentPage < pagination.totalPages) { %>
                <a href="?page=<%= pagination.currentPage + 1 %><%= searchQuery ? '&query=' + encodeURIComponent(searchQuery) : '' %>" class="pagination-btn">
                    Next <i class="fas fa-chevron-right"></i>
                </a>
            <% } else { %>
                <span class="pagination-btn disabled">
                    Next <i class="fas fa-chevron-right"></i>
                </span>
            <% } %>
        </div>

        <div style="text-align: center; margin-top: 10px; color: #718096;">
            <i class="fas fa-gift" style="margin-right: 5px;"></i>
            Showing <%= offers.length %> of <%= pagination.totalPages * 5 %> offers
        </div>
        <% } %>
        <% } else { %>
        <!-- No Data Display -->
        <div class="offer-table">
            <div class="no-data">
                <i class="fas fa-gift"></i>
                <h4>No offers found</h4>
                <p><%= searchQuery ? 'No offers match your search criteria.' : 'Start by adding your first offer!' %></p>
                <% if (searchQuery) { %>
                <button onclick="clearSearch()" class="add-offer-btn" style="margin-top: 15px; display: inline-block;">
                    <i class="fas fa-times"></i>
                    Clear Search
                </button>
                <% } %>
            </div>
        </div>
        <% } %>
    </div>

    <!-- Confirmation Modal -->
    <div id="confirmationModal" class="confirmation-modal">
        <div class="confirmation-content">
            <h3 id="confirmation-title">Confirm Action</h3>
            <p id="confirmation-message">Are you sure you want to proceed?</p>
            <div class="confirmation-buttons">
                <button class="confirmation-btn cancel" onclick="closeConfirmationModal()">Cancel</button>
                <button class="confirmation-btn confirm" id="confirmation-confirm-btn">Confirm</button>
            </div>
        </div>
    </div>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('search-input');
            const searchClear = document.getElementById('search-clear');
            const searchBtn = document.getElementById('search-btn');
            const loadingIndicator = document.getElementById('loading-indicator');
            const messageArea = document.getElementById('message-area');
            const offerTableBody = document.getElementById('offer-table-body');
            const paginationContainer = document.getElementById('pagination-container');
            const confirmationModal = document.getElementById('confirmationModal');
            const confirmationTitle = document.getElementById('confirmation-title');
            const confirmationMessage = document.getElementById('confirmation-message');
            const confirmationConfirmBtn = document.getElementById('confirmation-confirm-btn');
            
            let currentOfferId = null;
            let currentAction = null;

            // Check for URL parameters to show messages
            const urlParams = new URLSearchParams(window.location.search);
            const error = urlParams.get('error');
            const success = urlParams.get('success');
            
            if (error) {
                showMessage(decodeURIComponent(error), 'error');
            } else if (success) {
                showMessage(decodeURIComponent(success), 'success');
            }

            // Show/hide clear button based on input value
            if (searchInput.value) {
                searchClear.style.display = 'block';
            }
            
            searchInput.addEventListener('input', function() {
                searchClear.style.display = this.value ? 'block' : 'none';
            });
            
            // Clear search input
            searchClear.addEventListener('click', function() {
                searchInput.value = '';
                searchClear.style.display = 'none';
                performSearch(''); // Perform search with empty query
            });
            
            // Search on button click
            searchBtn.addEventListener('click', function() {
                performSearch(searchInput.value);
            });
            
            // Search on enter key
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    performSearch(this.value);
                }
            });
            
            // Search while typing with debounce
            let searchTimeout;
            searchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    performSearch(this.value);
                }, 500);
            });
            
            // Function to perform search
            function performSearch(query) {
                loadingIndicator.style.display = 'block';
                
                // Create URL with search parameter
                const url = new URL(window.location.href);
                url.pathname = '/admin/offersearch'; // Use search route
                url.searchParams.set('query', query);
                url.searchParams.set('page', '1');
                
                // Use fetch API to get search results
                fetch(url.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    
                    const newTableBody = doc.getElementById('offer-table-body');
                    const newPagination = doc.getElementById('pagination-container');
                    
                    if (newTableBody) {
                        offerTableBody.innerHTML = newTableBody.innerHTML;
                    }
                    
                    if (newPagination) {
                        paginationContainer.innerHTML = newPagination.innerHTML;
                    }
                    
                    // Reattach event listeners to status buttons
                    attachStatusButtonListeners();
                    
                    loadingIndicator.style.display = 'none';
                })
                .catch(error => {
                    console.error('Search error:', error);
                    loadingIndicator.style.display = 'none';
                    showMessage('An error occurred during search', 'error');
                });
            }
            
            // Function to clear search
            window.clearSearch = function() {
                searchInput.value = '';
                searchClear.style.display = 'none';
                performSearch('');
            };
            
            // Function to show messages
            function showMessage(message, type) {
                messageArea.textContent = message;
                messageArea.className = 'message-area ' + (type === 'success' ? 'success-message' : 'error-message');
                messageArea.style.display = 'block';
                
                setTimeout(() => {
                    messageArea.style.display = 'none';
                }, 5000);
            }
            
            // Function to open confirmation modal
            function openConfirmationModal(title, message, confirmCallback) {
                confirmationTitle.textContent = title;
                confirmationMessage.textContent = message;
                currentAction = confirmCallback;
                confirmationModal.style.display = 'flex';
            }
            
            // Function to close confirmation modal
            window.closeConfirmationModal = function() {
                confirmationModal.style.display = 'none';
                currentAction = null;
                currentOfferId = null;
            };
            
            // Confirmation button handler
            confirmationConfirmBtn.addEventListener('click', function() {
                if (currentAction) {
                    currentAction();
                }
                closeConfirmationModal();
            });
            
            // Close modal when clicking outside
            window.addEventListener('click', (e) => {
                if (e.target === confirmationModal) {
                    closeConfirmationModal();
                }
            });
            
            // Function to attach status button listeners
            function attachStatusButtonListeners() {
                document.querySelectorAll('.status-btn').forEach(button => {
                    button.addEventListener('click', function(e) {
                        e.preventDefault();
                        const offerId = this.dataset.id;
                        const currentStatus = this.dataset.status === 'true';
                        const action = currentStatus ? 'block' : 'activate';
                        
                        openConfirmationModal(
                            `${action === 'block' ? 'Block' : 'Activate'} Offer`,
                            `Are you sure you want to ${action} this offer?`,
                            function() {
                                updateOfferStatus(offerId, !currentStatus);
                            }
                        );
                    });
                });
            }
            
            // Function to update offer status
            function updateOfferStatus(offerId, newStatus) {
                fetch(`/admin/blockoffer/${offerId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        showMessage(result.message, 'success');
                        // Reload the page after a short delay
                        setTimeout(() => {
                            window.location.reload();
                        }, 1500);
                    } else {
                        showMessage(result.message || 'Error updating offer status', 'error');
                    }
                })
                .catch(error => {
                    console.error('Error updating offer status:', error);
                    showMessage('An error occurred while updating offer status', 'error');
                });
            }
            
            // Initial attachment of status button listeners
            attachStatusButtonListeners();
        });
    </script>
</body>
</html>