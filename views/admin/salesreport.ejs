<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Report - Admin</title>
    <style>
        /* General body and layout styling */
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7f9;
            margin: 0;
            display: flex;
        }

        /* Main content area */
        .main-content {
            flex-grow: 1;
            padding: 40px;
            overflow-y: auto;
        }

        /* Header and buttons */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        .header h1 {
            color: #2d3748;
            font-size: 2rem;
            font-weight: bold;
            margin: 0;
        }
        .header h1 i {
            margin-right: 10px;
            color: #4c51bf;
        }

        /* Filter Section */
        .filter-section {
            background-color: white;
            border-radius: 8px;
            padding: 25px;
            margin-bottom: 30px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .filter-title {
            color: #2d3748;
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 20px;
        }
        .filter-title i {
            color: #4c51bf;
            margin-right: 8px;
        }
        .btn-group-custom {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        .btn-type {
            background-color: #edf2f7;
            color: #4a5568;
            border: 1px solid #e2e8f0;
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            flex: 1 1 auto;
            min-width: 100px;
        }
        .btn-type:hover {
            background-color: #4c51bf;
            color: white;
            border-color: #4c51bf;
        }
        .btn-type.active {
            background-color: #4c51bf;
            color: white;
            border-color: #4c51bf;
        }
        .date-inputs {
            display: none;
            margin-top: 20px;
        }
        .date-inputs.show {
            display: block;
        }
        .date-row {
            display: flex;
            gap: 15px;
            align-items: flex-end;
        }
        .date-field {
            flex: 1;
        }
        .date-field label {
            display: block;
            margin-bottom: 8px;
            color: #4a5568;
            font-weight: 500;
            font-size: 0.9rem;
        }
        .date-field input {
            width: 100%;
            padding: 10px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            font-size: 0.95rem;
        }
        .date-field input:focus {
            outline: none;
            border-color: #4c51bf;
            box-shadow: 0 0 0 3px rgba(76, 81, 191, 0.2);
        }
        .btn-apply {
            background-color: #4c51bf;
            color: white;
            border: none;
            padding: 10px 30px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.95rem;
            transition: background-color 0.3s ease;
            margin-top: 20px;
        }
        .btn-apply:hover {
            background-color: #3b3f8f;
        }

        /* Stats Cards */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            background-color: white;
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }
        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
        }
        .stat-icon {
            width: 50px;
            height: 50px;
            background-color: #4c51bf;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 15px;
        }
        .stat-icon i {
            font-size: 24px;
            color: white;
        }
        .stat-icon.orders {
            background-color: #4c51bf;
        }
        .stat-icon.amount {
            background-color: #2f855a;
        }
        .stat-icon.discount {
            background-color: #dd6b20;
        }
        .stat-icon.net {
            background-color: #805ad5;
        }
        .stat-label {
            color: #718096;
            font-size: 0.9rem;
            margin-bottom: 5px;
        }
        .stat-value {
            color: #2d3748;
            font-size: 1.8rem;
            font-weight: bold;
            margin-bottom: 5px;
        }
        .stat-sub {
            color: #a0aec0;
            font-size: 0.8rem;
        }

        /* Table Section */
        .table-section {
            background-color: white;
            border-radius: 8px;
            padding: 25px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .table-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .table-header h3 {
            color: #2d3748;
            font-size: 1.2rem;
            font-weight: bold;
            margin: 0;
        }
        .table-header h3 i {
            color: #4c51bf;
            margin-right: 8px;
        }
        .download-buttons {
            display: flex;
            gap: 10px;
        }
        .btn-download {
            padding: 8px 20px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.95rem;
            transition: background-color 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .btn-pdf {
            background-color: #e53e3e;
            color: white;
        }
        .btn-pdf:hover {
            background-color: #c53030;
        }
        .btn-excel {
            background-color: #2f855a;
            color: white;
        }
        .btn-excel:hover {
            background-color: #276749;
        }

        /* Table styling */
        .sales-table {
            width: 100%;
            border-collapse: collapse;
        }
        .sales-table th, .sales-table td {
            text-align: left;
            padding: 15px;
            border-bottom: 1px solid #e2e8f0;
        }
        .sales-table th {
            background-color: #f7fafc;
            color: #4a5568;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 0.8rem;
        }
        .sales-table tr:hover {
            background-color: #edf2f7;
        }
        .order-number {
            font-weight: bold;
            color: #4c51bf;
        }
        .final-amount {
            font-weight: bold;
            color: #2f855a;
        }

        /* Status badges */
        .badge-status {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
            display: inline-block;
        }
        .badge-pending {
            background-color: #fed7d7;
            color: #c53030;
        }
        .badge-processing {
            background-color: #bee3f8;
            color: #2c5282;
        }
        .badge-shipped {
            background-color: #fefcbf;
            color: #975a16;
        }
        .badge-delivered {
            background-color: #c6f6d5;
            color: #2f855a;
        }
        .badge-cancelled {
            background-color: #e2e8f0;
            color: #4a5568;
        }

        /* Message area styling */
        .message-area {
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 8px;
            text-align: center;
            font-weight: bold;
            display: none;
        }
        .error-message {
            background-color: #fed7d7;
            color: #c53030;
            display: block;
        }
        .success-message {
            background-color: #c6f6d5;
            color: #2f855a;
            display: block;
        }
        .info-message {
            background-color: #bee3f8;
            color: #2c5282;
            display: block;
        }

        /* No data styling */
        .no-data {
            text-align: center;
            padding: 50px;
            color: #718096;
        }
        .no-data i {
            font-size: 60px;
            color: #cbd5e0;
            margin-bottom: 20px;
        }
        .no-data h4 {
            color: #4a5568;
            margin-bottom: 10px;
        }

        /* Loading indicator */
        .loading {
            display: none;
            text-align: center;
            padding: 20px;
            color: #4c51bf;
        }
        .loading-spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #4c51bf;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
            margin: 0 auto;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Responsive design */
        @media (max-width: 768px) {
            .stats-row {
                grid-template-columns: repeat(2, 1fr);
            }
            .date-row {
                flex-direction: column;
            }
            .btn-group-custom {
                flex-direction: column;
            }
            .btn-type {
                width: 100%;
            }
            .table-header {
                flex-direction: column;
                gap: 15px;
            }
            .download-buttons {
                width: 100%;
            }
            .btn-download {
                flex: 1;
                justify-content: center;
            }
        }

        @media (max-width: 480px) {
            .stats-row {
                grid-template-columns: 1fr;
            }
            .main-content {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <%- include("../partials/admin/navigation.ejs") %>
    
    <!-- Main Content -->
    <div class="main-content">
        <!-- Header -->
        <div class="header">
            <h1>
                <i class="fas fa-chart-line"></i>
                Sales Report
            </h1>
        </div>

        <!-- Message Area - Now controlled by JavaScript -->
        <div class="message-area" id="message-area"></div>

        <!-- Filter Section -->
        <div class="filter-section">
            <div class="filter-title">
                <i class="fas fa-filter"></i>
                Filter Reports
            </div>
            
            <form id="reportForm" method="GET" action="/admin/salesreport">
                <div class="btn-group-custom">
                    <button type="button" class="btn-type <%= reportType === 'daily' ? 'active' : '' %>" data-type="daily">Daily</button>
                    <button type="button" class="btn-type <%= reportType === 'weekly' ? 'active' : '' %>" data-type="weekly">Weekly</button>
                    <button type="button" class="btn-type <%= reportType === 'monthly' ? 'active' : '' %>" data-type="monthly">Monthly</button>
                    <button type="button" class="btn-type <%= reportType === 'yearly' ? 'active' : '' %>" data-type="yearly">Yearly</button>
                    <button type="button" class="btn-type <%= reportType === 'custom' ? 'active' : '' %>" data-type="custom">Custom</button>
                </div>
                
                <input type="hidden" name="type" id="reportType" value="<%= reportType %>">
                
                <div class="date-inputs <%= reportType === 'custom' ? 'show' : '' %>" id="customDateInputs">
                    <div class="date-row">
                        <div class="date-field">
                            <label for="startDate">Start Date</label>
                            <input type="date" name="startDate" id="startDate" value="<%= startDate %>">
                        </div>
                        <div class="date-field">
                            <label for="endDate">End Date</label>
                            <input type="date" name="endDate" id="endDate" value="<%= endDate %>">
                        </div>
                    </div>
                </div>
                
                <div style="text-align: right;">
                    <button type="submit" class="btn-apply">
                        <i class="fas fa-search" style="margin-right: 8px;"></i>
                        Apply Filter
                    </button>
                </div>
            </form>
        </div>

        <!-- Loading Indicator -->
        <div class="loading" id="loading-indicator">
            <div class="loading-spinner"></div>
            <p>Loading report data...</p>
        </div>

        <!-- Stats Cards -->
        <% if (orders && orders.length > 0) { %>
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon orders">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <div class="stat-label">Total Orders</div>
                <div class="stat-value"><%= overallStats.salesCount %></div>
                <div class="stat-sub">Completed orders</div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon amount">
                    <i class="fas fa-rupee-sign"></i>
                </div>
                <div class="stat-label">Total Amount</div>
                <div class="stat-value">₹<%= overallStats.totalOrderAmount.toFixed(2) %></div>
                <div class="stat-sub">Before discounts</div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon discount">
                    <i class="fas fa-tags"></i>
                </div>
                <div class="stat-label">Total Discounts</div>
                <div class="stat-value">₹<%= overallStats.totalDiscounts.toFixed(2) %></div>
                <div class="stat-sub">Coupon savings</div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon net">
                    <i class="fas fa-wallet"></i>
                </div>
                <div class="stat-label">Net Sales</div>
                <div class="stat-value">₹<%= overallStats.netSales.toFixed(2) %></div>
                <div class="stat-sub">Final revenue</div>
            </div>
        </div>

        <!-- Table Section -->
        <div class="table-section">
            <div class="table-header">
                <h3>
                    <i class="fas fa-list"></i>
                    Order Details
                </h3>
                
                <div class="download-buttons">
                    <a href="/admin/salesreport/download/pdf?type=<%= reportType %><%= reportType === 'custom' ? '&startDate=' + startDate + '&endDate=' + endDate : '' %>" 
                       class="btn-download btn-pdf">
                        <i class="fas fa-file-pdf"></i>
                        PDF
                    </a>
                    <a href="/admin/salesreport/download/excel?type=<%= reportType %><%= reportType === 'custom' ? '&startDate=' + startDate + '&endDate=' + endDate : '' %>" 
                       class="btn-download btn-excel">
                        <i class="fas fa-file-excel"></i>
                        Excel
                    </a>
                </div>
            </div>

            <div class="table-responsive">
                <table class="sales-table">
                    <thead>
                        <tr>
                            <th>Order No.</th>
                            <th>Date</th>
                            <th>Customer</th>
                            <th>Amount</th>
                            <th>Discount</th>
                            <th>Final Amount</th>
                            <th>Payment</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(order => { 
                            const finalAmount = order.orderAmount - (order.couponDiscount || 0);
                            let statusClass = 'badge-pending';
                            const status = order.orderStatus.toLowerCase();
                            
                            if (status.includes('processing')) statusClass = 'badge-processing';
                            else if (status.includes('shipped')) statusClass = 'badge-shipped';
                            else if (status.includes('delivered')) statusClass = 'badge-delivered';
                            else if (status.includes('cancelled')) statusClass = 'badge-cancelled';
                        %>
                        <tr>
                            <td><span class="order-number">#<%= order.orderNumber %></span></td>
                            <td><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
                            <td><%= order.userId ? order.userId.username : 'Guest' %></td>
                            <td>₹<%= order.orderAmount.toFixed(2) %></td>
                            <td>₹<%= (order.couponDiscount || 0).toFixed(2) %></td>
                            <td><span class="final-amount">₹<%= finalAmount.toFixed(2) %></span></td>
                            <td><%= order.paymentMethod %></td>
                            <td>
                                <span class="badge-status <%= statusClass %>">
                                    <%= order.orderStatus %>
                                </span>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } else { %>
        <!-- No Data Display -->
        <div class="table-section">
            <div class="no-data">
                <i class="fas fa-chart-line"></i>
                <h4>No orders found</h4>
                <p>There are no orders for the selected date range.</p>
                <p style="color: #a0aec0; font-size: 0.9rem;">
                    From: <%= new Date(startDate).toLocaleDateString('en-IN') %> 
                    To: <%= new Date(endDate).toLocaleDateString('en-IN') %>
                </p>
            </div>
        </div>
        <% } %>
    </div>

    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const typeButtons = document.querySelectorAll('.btn-type');
            const reportTypeInput = document.getElementById('reportType');
            const customDateInputs = document.getElementById('customDateInputs');
            const reportForm = document.getElementById('reportForm');
            const loadingIndicator = document.getElementById('loading-indicator');
            const messageArea = document.getElementById('message-area');

            // Check for URL parameters to show messages (optional)
            const urlParams = new URLSearchParams(window.location.search);
            const error = urlParams.get('error');
            const success = urlParams.get('success');
            
            if (error) {
                showMessage(decodeURIComponent(error), 'error');
            } else if (success) {
                showMessage(decodeURIComponent(success), 'success');
            }

            // Handle report type button clicks
            typeButtons.forEach(button => {
                button.addEventListener('click', function() {
                    const type = this.dataset.type;
                    
                    // Update active state
                    typeButtons.forEach(btn => btn.classList.remove('active'));
                    this.classList.add('active');
                    
                    // Update hidden input
                    reportTypeInput.value = type;
                    
                    // Show/hide custom date inputs
                    if (type === 'custom') {
                        customDateInputs.classList.add('show');
                    } else {
                        customDateInputs.classList.remove('show');
                        // Auto submit for predefined types
                        showLoading();
                        reportForm.submit();
                    }
                });
            });

            // Show loading on form submit
            reportForm.addEventListener('submit', function(e) {
                const type = reportTypeInput.value;
                
                if (type === 'custom') {
                    const startDate = document.getElementById('startDate').value;
                    const endDate = document.getElementById('endDate').value;
                    
                    if (!startDate || !endDate) {
                        e.preventDefault();
                        showMessage('Please select both start and end dates for custom range.', 'error');
                        return;
                    }
                    
                    if (new Date(startDate) > new Date(endDate)) {
                        e.preventDefault();
                        showMessage('Start date cannot be after end date.', 'error');
                        return;
                    }
                }
                
                showLoading();
            });

            // Function to show loading indicator
            function showLoading() {
                loadingIndicator.style.display = 'block';
            }

            // Function to show messages
            function showMessage(message, type) {
                messageArea.textContent = message;
                messageArea.className = 'message-area ' + (type === 'success' ? 'success-message' : 'error-message');
                messageArea.style.display = 'block';
                
                // Auto hide after 5 seconds
                setTimeout(() => {
                    messageArea.style.display = 'none';
                }, 5000);
            }

            // Hide loading on page load complete
            window.addEventListener('load', function() {
                loadingIndicator.style.display = 'none';
            });

            // Handle browser back/forward buttons
            window.addEventListener('pageshow', function(event) {
                if (event.persisted) {
                    loadingIndicator.style.display = 'none';
                }
            });
        });
    </script>
</body>
</html>