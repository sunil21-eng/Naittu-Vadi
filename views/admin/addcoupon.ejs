<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Coupon - Admin</title>
    <style>
        /* General body and layout styling */
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7f9;
            margin: 0;
            display: flex;
        }

        /* Main content area */
        .main-content {
            flex-grow: 1;
            padding: 40px;
            overflow-y: auto;
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        .header h1 {
            color: #2d3748;
            font-size: 2rem;
            font-weight: bold;
            margin: 0;
        }
        .header h1 i {
            margin-right: 10px;
            color: #4c51bf;
        }
        .back-btn {
            background-color: #edf2f7;
            color: #4a5568;
            border: 1px solid #e2e8f0;
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .back-btn:hover {
            background-color: #4c51bf;
            color: white;
            border-color: #4c51bf;
        }

        /* Form Container */
        .form-container {
            background-color: white;
            border-radius: 8px;
            padding: 30px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            max-width: 800px;
            margin: 0 auto;
        }

        /* Form Sections */
        .form-section {
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid #e2e8f0;
        }
        .form-section:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }
        .section-title {
            color: #2d3748;
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .section-title i {
            color: #4c51bf;
            font-size: 1.3rem;
        }

        /* Form Grid */
        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group.full-width {
            grid-column: span 2;
        }
        .form-label {
            display: block;
            margin-bottom: 8px;
            color: #4a5568;
            font-weight: 500;
            font-size: 0.95rem;
        }
        .form-label i {
            color: #4c51bf;
            margin-right: 6px;
            font-size: 0.9rem;
        }
        .form-control {
            width: 100%;
            padding: 12px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            font-size: 1rem;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }
        .form-control:focus {
            outline: none;
            border-color: #4c51bf;
            box-shadow: 0 0 0 3px rgba(76, 81, 191, 0.2);
        }
        .form-control[readonly] {
            background-color: #f7fafc;
            cursor: not-allowed;
        }
        textarea.form-control {
            resize: vertical;
            min-height: 100px;
        }

        /* Discount Type Toggle */
        .discount-type {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
        }
        .discount-option {
            flex: 1;
            position: relative;
        }
        .discount-option input[type="radio"] {
            display: none;
        }
        .discount-option label {
            display: block;
            padding: 12px;
            text-align: center;
            background-color: #edf2f7;
            border: 2px solid #e2e8f0;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 500;
        }
        .discount-option input[type="radio"]:checked + label {
            background-color: #4c51bf;
            border-color: #4c51bf;
            color: white;
        }
        .discount-option label i {
            margin-right: 8px;
        }

        /* Input with icon */
        .input-with-icon {
            position: relative;
        }
        .input-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #a0aec0;
        }
        .input-with-icon .form-control {
            padding-left: 35px;
        }

        /* Toggle Switch */
        .toggle-switch {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-top: 10px;
        }
        .switch {
            position: relative;
            display: inline-block;
            width: 60px;
            height: 34px;
        }
        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #cbd5e0;
            transition: .3s;
            border-radius: 34px;
        }
        .slider:before {
            position: absolute;
            content: "";
            height: 26px;
            width: 26px;
            left: 4px;
            bottom: 4px;
            background-color: white;
            transition: .3s;
            border-radius: 50%;
        }
        input:checked + .slider {
            background-color: #4c51bf;
        }
        input:checked + .slider:before {
            transform: translateX(26px);
        }
        .toggle-label {
            color: #4a5568;
            font-weight: 500;
        }
        .toggle-label i {
            color: #4c51bf;
            margin-right: 5px;
        }

        /* Form Actions */
        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
        }
        .btn {
            padding: 12px 30px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .btn-primary {
            background-color: #4c51bf;
            color: white;
        }
        .btn-primary:hover {
            background-color: #3b3f8f;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(76, 81, 191, 0.3);
        }
        .btn-secondary {
            background-color: #edf2f7;
            color: #4a5568;
            border: 1px solid #e2e8f0;
        }
        .btn-secondary:hover {
            background-color: #e2e8f0;
            transform: translateY(-2px);
        }
        .btn-danger {
            background-color: #e53e3e;
            color: white;
        }
        .btn-danger:hover {
            background-color: #c53030;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(229, 62, 62, 0.3);
        }

        /* Message area styling */
        .message-area {
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 8px;
            text-align: center;
            font-weight: bold;
            display: none;
        }
        .error-message {
            background-color: #fed7d7;
            color: #c53030;
            display: block;
        }
        .success-message {
            background-color: #c6f6d5;
            color: #2f855a;
            display: block;
        }
        .info-message {
            background-color: #bee3f8;
            color: #2c5282;
            display: block;
        }

        /* Loading indicator */
        .loading {
            display: none;
            text-align: center;
            padding: 20px;
            color: #4c51bf;
        }
        .loading-spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #4c51bf;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
            margin: 0 auto;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Helper text */
        .helper-text {
            color: #718096;
            font-size: 0.85rem;
            margin-top: 5px;
        }
        .helper-text i {
            color: #4c51bf;
            margin-right: 5px;
            font-size: 0.8rem;
        }

        /* Responsive design */
        @media (max-width: 768px) {
            .main-content {
                padding: 20px;
            }
            
            .form-grid {
                grid-template-columns: 1fr;
            }
            
            .form-group.full-width {
                grid-column: span 1;
            }
            
            .discount-type {
                flex-direction: column;
            }
            
            .form-actions {
                flex-direction: column;
            }
            
            .btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <%- include("../partials/admin/navigation.ejs") %>
    
    <!-- Main Content -->
    <div class="main-content">
        <!-- Header -->
        <div class="header">
            <h1>
                <i class="fas fa-plus-circle"></i>
                Add New Coupon
            </h1>
            <a href="/admin/coupon" class="back-btn">
                <i class="fas fa-arrow-left"></i>
                Back to Coupons
            </a>
        </div>

        <!-- Message Area -->
        <div class="message-area" id="message-area"></div>

        <!-- Form Container -->
        <div class="form-container">
            <form id="addCouponForm" method="POST" action="/admin/addcoupon">
                <!-- Basic Information Section -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fas fa-info-circle"></i>
                        Basic Information
                    </div>
                    
                    <div class="form-grid">
                        <div class="form-group full-width">
                            <label class="form-label">
                                <i class="fas fa-tag"></i>
                                Coupon Code
                            </label>
                            <input type="text" 
                                   class="form-control" 
                                   name="couponCode" 
                                   placeholder="e.g., SUMMER2024" 
                                   required
                                   pattern="[A-Za-z0-9]+"
                                   title="Only letters and numbers allowed, no spaces">
                            <div class="helper-text">
                                <i class="fas fa-info-circle"></i>
                                Use uppercase letters and numbers only (no spaces)
                            </div>
                        </div>

                        <div class="form-group full-width">
                            <label class="form-label">
                                <i class="fas fa-align-left"></i>
                                Description
                            </label>
                            <textarea class="form-control" 
                                      name="description" 
                                      placeholder="Enter coupon description..." 
                                      required></textarea>
                            <div class="helper-text">
                                <i class="fas fa-info-circle"></i>
                                Describe what this coupon offers to customers
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Discount Details Section -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fas fa-percent"></i>
                        Discount Details
                    </div>

                    <div class="discount-type">
                        <div class="discount-option">
                            <input type="radio" name="discountType" id="percentage" value="percentage" checked>
                            <label for="percentage">
                                <i class="fas fa-percent"></i>
                                Percentage Discount
                            </label>
                        </div>
                        <div class="discount-option">
                            <input type="radio" name="discountType" id="fixed" value="fixed">
                            <label for="fixed">
                                <i class="fas fa-rupee-sign"></i>
                                Fixed Amount
                            </label>
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label" id="discountValueLabel">
                                <i class="fas fa-percent"></i>
                                Discount Value (%)
                            </label>
                            <div class="input-with-icon">
                                <i class="fas fa-percent input-icon" id="discountIcon"></i>
                                <input type="number" 
                                       class="form-control" 
                                       name="discountValue" 
                                       id="discountValue"
                                       min="1" 
                                       max="100" 
                                       step="0.01"
                                       placeholder="Enter discount value" 
                                       required>
                            </div>
                            <div class="helper-text" id="discountHelper">
                                <i class="fas fa-info-circle"></i>
                                Enter value between 1 and 100
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-shopping-cart"></i>
                                Minimum Purchase (₹)
                            </label>
                            <div class="input-with-icon">
                                <i class="fas fa-rupee-sign input-icon"></i>
                                <input type="number" 
                                       class="form-control" 
                                       name="minPurchaseAmount" 
                                       min="0" 
                                       step="0.01"
                                       placeholder="0 = No minimum"
                                       value="0">
                            </div>
                            <div class="helper-text">
                                <i class="fas fa-info-circle"></i>
                                Leave 0 for no minimum purchase
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Usage Limits Section -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fas fa-chart-line"></i>
                        Usage Limits
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-redo-alt"></i>
                                Max Redemptions
                            </label>
                            <input type="number" 
                                   class="form-control" 
                                   name="maxRedemption" 
                                   min="0" 
                                   step="1"
                                   placeholder="0 = Unlimited"
                                   value="0">
                            <div class="helper-text">
                                <i class="fas fa-info-circle"></i>
                                Maximum number of times this coupon can be used
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-calendar-alt"></i>
                                Expiry Date
                            </label>
                            <input type="date" 
                                   class="form-control" 
                                   name="expiryDate" 
                                   required
                                   min="<%= new Date().toISOString().split('T')[0] %>">
                            <div class="helper-text">
                                <i class="fas fa-info-circle"></i>
                                Coupon will expire at the end of this day
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Status Section -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fas fa-toggle-on"></i>
                        Status
                    </div>

                    <div class="toggle-switch">
                        <label class="switch">
                            <input type="checkbox" name="status" value="active" checked>
                            <span class="slider"></span>
                        </label>
                        <span class="toggle-label">
                            <i class="fas fa-check-circle"></i>
                            Active (Coupon will be available immediately)
                        </span>
                    </div>
                    <div class="helper-text" style="margin-top: 10px;">
                        <i class="fas fa-info-circle"></i>
                        Inactive coupons won't be visible to customers
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <a href="/admin/coupon" class="btn btn-secondary">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                    <button type="reset" class="btn btn-danger">
                        <i class="fas fa-undo"></i>
                        Reset
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i>
                        Create Coupon
                    </button>
                </div>
            </form>
        </div>

        <!-- Loading Indicator -->
        <div class="loading" id="loading-indicator">
            <div class="loading-spinner"></div>
            <p>Creating coupon...</p>
        </div>
    </div>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('addCouponForm');
            const messageArea = document.getElementById('message-area');
            const loadingIndicator = document.getElementById('loading-indicator');
            
            // Discount type toggle elements
            const percentageRadio = document.getElementById('percentage');
            const fixedRadio = document.getElementById('fixed');
            const discountValueLabel = document.getElementById('discountValueLabel');
            const discountIcon = document.getElementById('discountIcon');
            const discountHelper = document.getElementById('discountHelper');
            const discountValue = document.getElementById('discountValue');

            // Set minimum date for expiry date input
            const expiryDateInput = document.querySelector('input[name="expiryDate"]');
            const today = new Date().toISOString().split('T')[0];
            expiryDateInput.setAttribute('min', today);

            // Handle discount type change
            function updateDiscountFields() {
                if (percentageRadio.checked) {
                    // Percentage mode
                    discountValueLabel.innerHTML = '<i class="fas fa-percent"></i> Discount Value (%)';
                    discountIcon.className = 'fas fa-percent input-icon';
                    discountValue.max = 100;
                    discountValue.min = 1;
                    discountValue.step = 0.01;
                    discountValue.placeholder = 'Enter percentage';
                    discountHelper.innerHTML = '<i class="fas fa-info-circle"></i> Enter value between 1 and 100';
                } else {
                    // Fixed amount mode
                    discountValueLabel.innerHTML = '<i class="fas fa-rupee-sign"></i> Discount Amount (₹)';
                    discountIcon.className = 'fas fa-rupee-sign input-icon';
                    discountValue.removeAttribute('max');
                    discountValue.min = 1;
                    discountValue.step = 0.01;
                    discountValue.placeholder = 'Enter amount';
                    discountHelper.innerHTML = '<i class="fas fa-info-circle"></i> Enter the discount amount in rupees';
                }
            }

            percentageRadio.addEventListener('change', updateDiscountFields);
            fixedRadio.addEventListener('change', updateDiscountFields);

            // Form validation
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Get form values
                const couponCode = document.querySelector('input[name="couponCode"]').value.trim();
                const description = document.querySelector('textarea[name="description"]').value.trim();
                const discountValue = parseFloat(document.querySelector('input[name="discountValue"]').value);
                const minPurchase = parseFloat(document.querySelector('input[name="minPurchaseAmount"]').value);
                const maxRedemption = parseInt(document.querySelector('input[name="maxRedemption"]').value);
                const expiryDate = document.querySelector('input[name="expiryDate"]').value;

                // Validate coupon code
                if (!couponCode) {
                    showMessage('Please enter a coupon code', 'error');
                    return;
                }
                if (!/^[A-Za-z0-9]+$/.test(couponCode)) {
                    showMessage('Coupon code can only contain letters and numbers (no spaces)', 'error');
                    return;
                }

                // Validate description
                if (!description) {
                    showMessage('Please enter a description', 'error');
                    return;
                }
                if (description.length < 10) {
                    showMessage('Description must be at least 10 characters long', 'error');
                    return;
                }

                // Validate discount value
                if (!discountValue || discountValue <= 0) {
                    showMessage('Please enter a valid discount value', 'error');
                    return;
                }

                if (percentageRadio.checked) {
                    if (discountValue > 100) {
                        showMessage('Percentage discount cannot exceed 100%', 'error');
                        return;
                    }
                }

                // Validate min purchase
                if (minPurchase < 0) {
                    showMessage('Minimum purchase amount cannot be negative', 'error');
                    return;
                }

                // Validate max redemption
                if (maxRedemption < 0) {
                    showMessage('Max redemptions cannot be negative', 'error');
                    return;
                }

                // Validate expiry date
                if (!expiryDate) {
                    showMessage('Please select an expiry date', 'error');
                    return;
                }

                const selectedDate = new Date(expiryDate);
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                
                if (selectedDate < today) {
                    showMessage('Expiry date cannot be in the past', 'error');
                    return;
                }

                // Show loading and submit form
                showLoading();
                this.submit();
            });

            // Handle reset button
            document.querySelector('button[type="reset"]').addEventListener('click', function(e) {
                e.preventDefault();
                if (confirm('Are you sure you want to reset all fields?')) {
                    form.reset();
                    updateDiscountFields();
                }
            });

            // Function to show loading
            function showLoading() {
                loadingIndicator.style.display = 'block';
            }

            // Function to show messages
            function showMessage(message, type) {
                messageArea.textContent = message;
                messageArea.className = 'message-area ' + (type === 'success' ? 'success-message' : 'error-message');
                messageArea.style.display = 'block';
                
                // Auto hide after 5 seconds
                setTimeout(() => {
                    messageArea.style.display = 'none';
                }, 5000);
            }

            // Check for URL parameters to show messages
            const urlParams = new URLSearchParams(window.location.search);
            const error = urlParams.get('error');
            const success = urlParams.get('success');
            
            if (error) {
                showMessage(decodeURIComponent(error), 'error');
            } else if (success) {
                showMessage(decodeURIComponent(success), 'success');
            }

            // Prevent form resubmission on page refresh
            if (window.history.replaceState) {
                window.history.replaceState(null, null, window.location.pathname);
            }
        });
    </script>
</body>
</html>