<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Artemis Footer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #3a86ff;
            --secondary-color: #ff006e;
            --dark-color: #2b2d42;
            --light-color: #f8f9fa;
        }

        /* Footer - exactly matching header height and style */
        .artemis-footer {
            background-color: var(--dark-color);
            color: white;
            padding: 15px 0;
            width: 100%;
            font-size: 0.85rem;
        }

        .artemis-footer .container {
            max-width: 100%;
            padding: 0 15px;
        }

        /* Footer brand - matching navbar-brand */
        .artemis-footer .footer-brand {
            font-weight: 800;
            color: var(--primary-color);
            font-size: 1.2rem;
            letter-spacing: 0.5px;
            margin-bottom: 5px;
        }

        .artemis-footer .footer-brand i {
            color: var(--primary-color);
            margin-right: 5px;
        }

        /* About text - compact */
        .artemis-footer .about-text {
            color: #ddd;
            font-size: 0.85rem;
            line-height: 1.4;
            margin: 0;
        }

        /* Contact info - matching top-bar style */
        .artemis-footer .contact-info {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .artemis-footer .contact-info span {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .artemis-footer .contact-info i {
            color: var(--primary-color);
            width: 16px;
        }

        /* Address section */
        .artemis-footer .address {
            color: #ddd;
            line-height: 1.4;
        }

        .artemis-footer .address i {
            color: var(--primary-color);
            width: 16px;
            margin-right: 5px;
        }

        /* Social icons - matching header button style */
        .artemis-footer .social-icons {
            display: flex;
            gap: 8px;
        }

        .artemis-footer .social-icons a {
            color: white;
            background: rgba(255, 255, 255, 0.1);
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: all 0.3s ease;
            font-size: 0.9rem;
        }

        .artemis-footer .social-icons a:hover {
            background: var(--primary-color);
            transform: translateY(-2px);
        }

        /* Safety warning - compact */
        .artemis-footer .safety-warning {
            background: rgba(230, 57, 70, 0.1);
            padding: 5px 10px;
            border-radius: 4px;
            color: #ff6b6b;
            font-size: 0.8rem;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            margin: 8px 0;
        }

        .artemis-footer .safety-warning i {
            color: #ff6b6b;
        }

        /* Footer bottom - matching top-bar style */
        .artemis-footer .footer-bottom {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: 10px;
            padding-top: 10px;
            color: #999;
            font-size: 0.8rem;
        }

        .artemis-footer .footer-bottom i {
            color: var(--primary-color);
        }

        /* Divider - matching header style */
        .artemis-footer .divider {
            color: rgba(255, 255, 255, 0.2);
            margin: 0 8px;
        }

        /* ========== FULLY RESPONSIVE FOOTER - MOBILE & DESKTOP ========== */
        /* Large desktop screens (1200px+) - keep original layout */
        
        /* Desktop and tablet (992px - 1199px) - adjust spacing */
        @media (max-width: 1199px) {
            .artemis-footer .contact-info {
                gap: 12px;
            }
            .artemis-footer .about-text {
                font-size: 0.82rem;
            }
        }

        /* Tablet (768px - 991px) - reflow content but keep all elements visible */
        @media (max-width: 991px) {
            .artemis-footer .row.align-items-center {
                text-align: center;
            }
            .artemis-footer .footer-brand {
                text-align: center;
                margin-bottom: 10px;
            }
            .artemis-footer .about-text {
                text-align: center;
                margin-bottom: 12px;
            }
            .artemis-footer .social-icons {
                justify-content: center;
                margin-top: 5px;
            }
            .artemis-footer .contact-info {
                justify-content: center;
                gap: 8px;
            }
            .artemis-footer .address {
                text-align: center;
            }
            .artemis-footer .safety-warning {
                justify-content: center;
                width: auto;
                margin-top: 8px;
            }
            .artemis-footer .footer-bottom .row {
                text-align: center;
            }
            .artemis-footer .footer-bottom .col-md-6 {
                text-align: center !important;
            }
        }

        /* Mobile (up to 767px) - full stacking, no content loss, all info accessible */
        @media (max-width: 767px) {
            .artemis-footer {
                padding: 20px 0 15px;
            }
            .artemis-footer .footer-brand {
                font-size: 1.1rem;
                margin-bottom: 8px;
            }
            .artemis-footer .about-text {
                font-size: 0.8rem;
                padding: 0 5px;
                margin-bottom: 10px;
            }
            .artemis-footer .social-icons {
                gap: 10px;
                margin-bottom: 8px;
            }
            .artemis-footer .social-icons a {
                width: 34px;
                height: 34px;
                font-size: 1rem;
            }
            /* Contact info - vertical stack for better mobile readability */
            .artemis-footer .contact-info {
                flex-direction: column;
                align-items: center;
                gap: 8px;
            }
            .artemis-footer .divider {
                display: none;  /* Hide dividers on mobile for cleaner vertical layout */
            }
            .artemis-footer .contact-info span {
                justify-content: center;
                width: 100%;
            }
            .artemis-footer .address {
                text-align: center;
                font-size: 0.8rem;
                margin-top: 5px;
                word-break: break-word;
            }
            .artemis-footer .safety-warning {
                display: flex;
                justify-content: center;
                width: 100%;
                margin: 10px 0 5px;
                font-size: 0.75rem;
            }
            .artemis-footer .footer-bottom {
                text-align: center;
                margin-top: 12px;
                padding-top: 12px;
            }
            .artemis-footer .footer-bottom .row > div {
                margin-bottom: 6px;
            }
            .artemis-footer .footer-bottom .col-md-6:last-child {
                margin-bottom: 0;
            }
            .artemis-footer .footer-bottom .text-md-end {
                text-align: center !important;
            }
            /* Adjust row margins for mobile */
            .artemis-footer .row.mt-2 {
                margin-top: 8px !important;
            }
            .artemis-footer .row.mt-1 {
                margin-top: 6px !important;
            }
        }

        /* Extra small devices (up to 480px) - fine-tune spacing */
        @media (max-width: 480px) {
            .artemis-footer .container {
                padding: 0 12px;
            }
            .artemis-footer .about-text {
                font-size: 0.75rem;
                line-height: 1.3;
            }
            .artemis-footer .contact-info span {
                font-size: 0.75rem;
            }
            .artemis-footer .address {
                font-size: 0.74rem;
            }
            .artemis-footer .safety-warning {
                font-size: 0.7rem;
                padding: 4px 8px;
            }
            .artemis-footer .footer-bottom {
                font-size: 0.7rem;
            }
            .artemis-footer .social-icons a {
                width: 30px;
                height: 30px;
                font-size: 0.85rem;
            }
        }

        /* Ensure no horizontal scroll on any device */
        body {
            overflow-x: hidden;
            margin: 0;
            padding: 0;
        }
        
        /* Keep all original spacing for desktop while making mobile perfect */
        .artemis-footer .row {
            margin-left: 0;
            margin-right: 0;
        }
        
        .artemis-footer .col-md-3,
        .artemis-footer .col-md-6,
        .artemis-footer .col-md-4,
        .artemis-footer .col-md-8,
        .artemis-footer .col-12 {
            padding-left: 10px;
            padding-right: 10px;
        }
        
        @media (max-width: 767px) {
            .artemis-footer .col-md-3,
            .artemis-footer .col-md-6,
            .artemis-footer .col-md-4,
            .artemis-footer .col-md-8,
            .artemis-footer .col-12 {
                padding-left: 8px;
                padding-right: 8px;
            }
        }
    </style>
</head>
<body>
    <!-- Your page content here -->

    <!-- Footer - Fully responsive, all content preserved, no functionality changed -->
    <footer class="artemis-footer">
        <div class="container">
            <!-- First Row - Brand & About (fully responsive) -->
            <div class="row align-items-center">
                <div class="col-md-3">
                    <div class="footer-brand">
                        <i class="fas fa-star"></i> Artemis Crakers
                    </div>
                </div>
                <div class="col-md-6">
                    <p class="about-text">
                        Premium quality crackers since 2010. Making celebrations sparkle! 🎆
                    </p>
                </div>
                <div class="col-md-3 text-md-end">
                    <div class="social-icons">
