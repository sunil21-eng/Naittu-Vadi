                </div>
            </div>

            <!-- Footer Bottom - Exactly like top-bar, fully responsive -->
            <div class="footer-bottom">
                <div class="row">
                    <div class="col-md-6">
                        <span><i class="far fa-copyright"></i> 2024 Artemis Crakers • Made with <i class="fas fa-heart" style="color: #ff006e;"></i></span>
                    </div>
                    <div class="col-md-6 text-md-end">
