<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Artemis Footer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjsflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #3a86ff;
            --secondary-color: #ff006e;
            --dark-color: #2b2d42;
            --light-color: #f8f9fa;
        }

        /* Footer - exactly matching header height and style */
        .artemis-footer {
            background-color: var(--dark-color);
            color: white;
            padding: 15px 0;
            width: 100%;
            font-size: 0.85rem;
        }

        .artemis-footer .container {
            max-width: 100%;
            padding: 0 15px;
        }

        /* Footer brand - matching navbar-brand */
        .artemis-footer .footer-brand {
            font-weight: 800;
            color: var(--primary-color);
            font-size: 1.2rem;
            letter-spacing: 0.5px;
            margin-bottom: 5px;
        }

        .artemis-footer .footer-brand i {
            color: var(--primary-color);
            margin-right: 5px;
        }

        /* About text - compact */
        .artemis-footer .about-text {
            color: #ddd;
            font-size: 0.85rem;
            line-height: 1.4;
            margin: 0;
        }

        /* Contact info - matching top-bar style */
        .artemis-footer .contact-info {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .artemis-footer .contact-info span {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .artemis-footer .contact-info i {
            color: var(--primary-color);
            width: 16px;
        }

        /* Address section */
        .artemis-footer .address {
            color: #ddd;
            line-height: 1.4;
        }

        .artemis-footer .address i {
            color: var(--primary-color);
            width: 16px;
            margin-right: 5px;
        }

        /* Social icons - matching header button style */
        .artemis-footer .social-icons {
            display: flex;
            gap: 8px;
        }

        .artemis-footer .social-icons a {
            color: white;
            background: rgba(255, 255, 255, 0.1);
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: all 0.3s ease;
            font-size: 0.9rem;
        }

        .artemis-footer .social-icons a:hover {
            background: var(--primary-color);
            transform: translateY(-2px);
        }

        /* Safety warning - compact */
        .artemis-footer .safety-warning {
            background: rgba(230, 57, 70, 0.1);
            padding: 5px 10px;
            border-radius: 4px;
            color: #ff6b6b;
            font-size: 0.8rem;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            margin: 8px 0;
        }

        .artemis-footer .safety-warning i {
            color: #ff6b6b;
        }

        /* Footer bottom - matching top-bar style */
        .artemis-footer .footer-bottom {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: 10px;
            padding-top: 10px;
            color: #999;
            font-size: 0.8rem;
        }

        .artemis-footer .footer-bottom i {
            color: var(--primary-color);
        }

        /* Divider - matching header style */
        .artemis-footer .divider {
            color: rgba(255, 255, 255, 0.2);
            margin: 0 8px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .artemis-footer .contact-info {
                flex-direction: column;
                gap: 5px;
            }
            
            .artemis-footer .footer-bottom .row {
                flex-direction: column;
                text-align: center;
                gap: 5px;
            }
            
            .artemis-footer .social-icons {
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <!-- Your page content here -->

    <!-- Footer - Same height as header (15px padding top/bottom) -->
    <footer class="artemis-footer">
        <div class="container">
            <!-- First Row - Brand & About -->
            <div class="row align-items-center">
                <div class="col-md-3">
                    <div class="footer-brand">
                        <i class="fas fa-star"></i> Artemis Crakers
                    </div>
                </div>
                <div class="col-md-6">
                    <p class="about-text">
                        Premium quality crackers since 2010. Making celebrations sparkle! 🎆
                    </p>
                </div>
                <div class="col-md-3 text-md-end">
                    <div class="social-icons">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-whatsapp"></i></a>
                    </div>
                </div>
            </div>

            <!-- Second Row - Contact & Address (compact) -->
            <div class="row mt-2">
                <div class="col-md-8">
                    <div class="contact-info">
                        <span><i class="fas fa-phone"></i> +91 78688 29460</span>
                        <span class="divider">|</span>
                        <span><i class="fas fa-envelope"></i> opensurfaces21@gmail.com</span>
                        <span class="divider">|</span>
                        <span><i class="fas fa-map-marker-alt"></i>Krishnagiri - 600001</span>
                    </div>
                </div>
                <div class="col-md-4 text-md-end">
                    <span class="safety-warning">
                        <i class="fas fa-exclamation-triangle"></i> 18+ Only • Celebrate Safely
                    </span>
                </div>
            </div>

            <!-- Third Row - Full Address -->
            <div class="row mt-1">
                <div class="col-12">
                    <div class="address">
                        <i class="fas fa-store"></i> Dharmaraja nagar • 
                        <i class="fas fa-warehouse ms-2"></i> Singarapettai, Krishnagiri
                    </div>
                </div>
            </div>

            <!-- Footer Bottom - Exactly like top-bar -->
            <div class="footer-bottom">
                <div class="row">
                    <div class="col-md-6">
                        <span><i class="far fa-copyright"></i> 2024 Artemis Crakers • Made with <i class="fas fa-heart" style="color: #ff006e;"></i></span>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <span><i class="fas fa-id-card"></i> Sale to minors prohibited</span>
                    </div>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>