<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Navigation CSS Only</title>
    <style>
        /* Sidebar Navigation */
        .sidebar {
            width: 250px;
            background-color: #fff;
            padding: 2rem;
            box-shadow: 2px 0 4px rgba(0, 0, 0, 0.05);
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .logo {
            font-weight: bold;
            font-size: 1.2rem;
            margin-bottom: 2rem;
        }

        .nav-links {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .nav-links a {
            text-decoration: none;
            color: #666;
            font-size: 0.9rem;
            padding: 1rem 1.5rem;
            border-radius: 8px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .nav-links a.active,
        .nav-links a:hover {
            background-color: #f0f3ff;
            color: #4a60e0;
        }

        .nav-links a.active {
            font-weight: bold;
        }
    </style>
</head>

<body>
    <nav class="sidebar">
        <div class="logo">Artemis Admin</div>
        <div class="nav-links">
            <a href="/admin" class="<%=(typeof currentPage !== 'undefined' && currentPage === 'dashboard') ? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
                Dashboard
            </a>
            <a href="/admin/productLists" class="<%=(typeof currentPage !== 'undefined' && currentPage === 'products') ? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <path d="M16 10a4 4 0 0 1-8 0" />
                </svg>
                Products
            </a>
            <a href="/admin/orders" class="<%=(typeof currentPage !== 'undefined' && currentPage === 'orders' ) ? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                    <line x1="16" y1="13" x2="8" y2="13" />
                    <line x1="16" y1="17" x2="8" y2="17" />
                    <polyline points="10 9 9 9 8 9" />
                </svg>
                Orders
            </a>
            <a href="/admin/user" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'customers') ? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
                Customers
            </a>
            <a href="/admin/category" class="<%=(typeof currentPage !== 'undefined' && currentPage === 'categories') ? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <circle cx="12" cy="12" r="3" />
                    <path d="M16 16l4 4" />
                    <path d="M8 8l-4-4" />
                </svg>
                Categories
            </a>
            <a href="/admin/coupon" class="<%=(typeof currentPage !== 'undefined' && currentPage === 'report')? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path
                        d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5A5.5 5.5 0 0 1 7.5 3C9.08 3 10.73 4.22 12 5.5c1.27-1.28 2.92-2.5 4.5-2.5A5.5 5.5 0 0 1 22 8.5c0 3.78-3.4 6.86-8.55 11.53L12 21.35z" />
                </svg>
                Coupons
            </a>
             <a href="/admin/offer" class="<%=(typeof currentPage !== 'undefined' && currentPage === 'report')? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path
                        d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5A5.5 5.5 0 0 1 7.5 3C9.08 3 10.73 4.22 12 5.5c1.27-1.28 2.92-2.5 4.5-2.5A5.5 5.5 0 0 1 22 8.5c0 3.78-3.4 6.86-8.55 11.53L12 21.35z" />
                </svg>
                Offers
            </a>
            <a href="/admin/salesreport" class="<%=(typeof currentPage !== 'undefined' && currentPage === 'report')? 'active' : '' %>">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path
                        d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5A5.5 5.5 0 0 1 7.5 3C9.08 3 10.73 4.22 12 5.5c1.27-1.28 2.92-2.5 4.5-2.5A5.5 5.5 0 0 1 22 8.5c0 3.78-3.4 6.86-8.55 11.53L12 21.35z" />
                </svg>
                Report
            </a>
            <a href="/admin/logout" class="btn-logout btn-outline-primary">
                <i class="fas fa-user-plus me-1"></i>logout
            </a>
        </div>
    </nav>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
</body>

</html>